SELECT  NVL(paa.date_start,paa.date_projected_start) start_date 
        ,NVL(paa.date_end,paa.date_projected_end) end_date 
       ,paattl.name Leave_type 
       ,fcl.meaning  leave_category 
       ,paa.absence_days 
       ,(SELECT meaning from hr_lookups where 'A' = lookup_code(+) and 'LEAVE_STATUS' = lookup_type(+)) 
       approval_status 
       ,decode(paa.date_start,null,
                                   (SELECT meaning from fnd_lookup_values 
                                    where lookup_type ='ABSENCE_STATUS' and lookup_code ='PLANNED'
 and language = userenv('LANG')),
                                   (SELECT meaning from fnd_lookup_values 
                                    where lookup_type ='ABSENCE_STATUS' and lookup_code ='CONFIRMED'
and language = userenv('LANG'))) 
        absence_status
FROM per_absence_attendances paa 
     ,per_absence_attendance_types paat
     ,per_abs_attendance_types_tl paattl
     ,hr_lookups fcl
     , per_all_people_f p
WHERE paa.person_id in (select person_id from per_all_people_f k
where 1=1
and employee_number = :P_Emp_No
and sysdate between effective_start_date and effective_end_date 
and rownum =1)
and (trunc(sysdate)
    between p.effective_start_date and p.effective_end_date)
      and paa.person_id = p.person_id
      and paa.business_group_id+0 = 81
      and paa.absence_attendance_type_id = paat.absence_attendance_type_id 
      and paat.absence_attendance_type_id = paattl.absence_attendance_type_id
      and paattl.language = userenv('LANG')
      and fcl.lookup_type(+) = 'ABSENCE_CATEGORY'
      and paat.absence_category = fcl.lookup_code(+) 
      and ((hr_api.return_legislation_code(paa.business_group_id) = 'GB'
         and nvl(paat.absence_category,'#')  not in
('M','GB_PAT_ADO','GB_PAT_BIRTH','GB_ADO','GB_ADDL_PAT_ADOPT','GB_ADDL_PAT_BIRTH','GB_SPL_BIRTH','GB_SPL_ADOPT')) 
 or
        (hr_api.return_legislation_code(paat.business_group_id) <> 'GB'
         and nvl(paat.absence_category,'#') not in
		 ('GB_PAT_ADO','GB_PAT_BIRTH','GB_ADO','GB_ADDL_PAT_ADOPT','GB_ADDL_PAT_BIRTH' ,'GB_SPL_BIRTH','GB_SPL_ADOPT')))
      and not exists 
      ( select 'e' 
        from hr_api_transactions t
         WHERE 
        t.selected_person_id = paa.person_id 
--        and t.CREATOR_PERSON_ID  = nvl(:3,t.CREATOR_PERSON_ID)
        and t.transaction_ref_table='PER_ABSENCE_ATTENDANCES'
         and t.transaction_ref_id = paa.absence_attendance_id
         and not(hr_absutil_ss.getabsencetype(t.transaction_id,    NULL) IS NULL
         and t.status = 'W') 
         and t.status not in ('D','E','AC')
      )
      union all
select hr_absutil_ss.getStartDate(hat.transaction_id,null) start_date
       ,hr_absutil_ss.getEndDate(hat.transaction_id,null) end_date
       ,hr_absutil_ss.getAbsenceType(hat.transaction_id,null) leave_type 
 ,hr_absutil_ss.getAbsenceCategory(hat.transaction_id,null)  leave_category  
     ,hr_absutil_ss.getAbsenceDaysDuration(hat.transaction_id,null)  absence_days     
       ,hr_absutil_ss.getApprovalStatus(hat.transaction_id,null) approval_status
       ,hr_absutil_ss.getAbsenceStatus(hat.transaction_id,null) absence_status             
from hr_api_transactions hat
     ,hr_api_transaction_steps hats
     ,per_all_people_f p
where hat.TRANSACTION_REF_TABLE='PER_ABSENCE_ATTENDANCES'
and hat.TRANSACTION_GROUP='ABSENCE_MGMT'
and hat.TRANSACTION_IDENTIFIER='ABSENCES'
and hat.TRANSACTION_REF_ID is not null
and hat.SELECTED_PERSON_ID  in (select person_id from per_all_people_f k
where 1=1
and employee_number = :P_Emp_No
and sysdate between effective_start_date and effective_end_date 
and rownum =1)
--and hat.CREATOR_PERSON_ID  = nvl(:5,hat.CREATOR_PERSON_ID)
and (trunc(sysdate)
    between p.effective_start_date and p.effective_end_date)
      and hat.SELECTED_PERSON_ID = p.person_id
and hat.transaction_id=hats.transaction_id(+)
and hat.status not in ('D','E','AC')
and not (hr_absutil_ss.getabsencetype(hat.transaction_id,null) is null and hat.status='W')
UNION ALL
select  tv1.date_value start_date 
       ,tv4.date_value end_date
       ,paat.name leave_type
       ,fcl.meaning leave_category
        ,null absence_days
       ,(SELECT meaning from hr_lookups where 'PA' = lookup_code(+) and 'LEAVE_STATUS' = lookup_type(+)) approval_status
       ,null absence_status
FROM  hr_api_transactions t
     ,hr_api_transaction_steps ts
     ,hr_api_transaction_values tv 
     ,hr_api_transaction_values tv1 
     ,hr_api_transaction_values tv2
     ,hr_api_transaction_values tv3
     ,hr_api_transaction_values tv4
     ,hr_lookups fcl
     ,per_abs_attendance_types_v paat 
     ,per_all_people_f p
WHERE 
    t.selected_person_id in  (select person_id from per_all_people_f k
where 1=1
and employee_number = :P_Emp_No
and sysdate between effective_start_date and effective_end_date 
and rownum =1)
    and t.status = 'Y' 
    and t.transaction_id = ts.transaction_id 
    and ts.api_name = 'HR_LOA_SS.PROCESS_API'
    and ts.transaction_step_id = tv.transaction_step_id 
    and tv.name = 'P_DATE_PROJECTED_START' 
    and ts.transaction_step_id = tv1.transaction_step_id 
    and tv1.name = 'P_DATE_START'
    and ts.transaction_step_id = tv3.transaction_step_id 
    and tv3.name = 'P_DATE_PROJECTED_END' 
    and ts.transaction_step_id = tv4.transaction_step_id 
    and tv4.name = 'P_DATE_END'
    and ts.transaction_step_id = tv2.transaction_step_id 
    and tv2.name='P_ABSENCE_ATTENDANCE_TYPE_ID'
    and paat.ABSENCE_ATTENDANCE_TYPE_ID=tv2.number_value 
    and paat.absence_category = fcl.lookup_code(+)
    and fcl.lookup_type(+) = 'ABSENCE_CATEGORY'
    and (trunc(sysdate)
    between p.effective_start_date and p.effective_end_date)
      and t.SELECTED_PERSON_ID = p.person_id
      order by 1 desc;  
