select papf.employee_number,papf.full_name,
       round(xxoa_absence_duration.get_leave_ent(paaf.assignment_id,'Annual Leave Balance',trunc(sysdate)),3) Annual_Leave_Balance,
       round(xxoa_absence_duration.get_leave_ent(paaf.assignment_id,'Sick Leave Bank Plan',trunc(sysdate)),3) Sick_Leave_Bank_Balance,
       CASE
       WHEN
       round(xxoa_absence_duration.get_leave_ent(paaf.assignment_id,'Off in Lieu Bank Balance',trunc(sysdate)),3) = -9999999
       THEN 0
       ELSE
       round(xxoa_absence_duration.get_leave_ent(paaf.assignment_id,'Off in Lieu Bank Balance',trunc(sysdate)),3)
       END AS Off_in_Lieu_Bank_Balance
from
per_all_people_f papf,
per_all_assignments_f paaf
where 
    papf.person_id = paaf.person_id
AND paaf.primary_flag = 'Y'
AND papf.CURRENT_EMPLOYEE_FLAG = 'Y'   
and trunc(sysdate) between papf.effective_start_date and papf.effective_end_date
and trunc(sysdate) between paaf.effective_start_date and paaf.effective_end_date
and paaf.payroll_id in (65,67)
and paaf.vacancy_id is null
and papf.employee_number = :emp_no

