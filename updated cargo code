### Step 3 — Wrap the multiplier logic with the payroll check

Find the SR 441873 block you already have:

```sql
--Added for SR 441873 Starts
BEGIN
   SELECT COUNT (1) + 1
   INTO   v_occurence_no
   FROM   xxoa_early_late_deduction
   WHERE  person_id = v_person_id
   AND    period_id = p_period_id
   AND    TRUNC (punch_date) < TRUNC (v_date)
   AND    transaction_type = 'LATE_COMING';
EXCEPTION
   WHEN OTHERS THEN
      v_occurence_no :=1;
END;

IF v_occurence_no <= 2 THEN
   v_multiplier:=0;
ELSIF v_occurence_no <= 3 THEN
   v_multiplier:=1;
ELSIF v_occurence_no <= 4 THEN
   v_multiplier:=1.5;
ELSIF v_occurence_no <= 5 THEN
   v_multiplier:=2;
ELSE
   v_multiplier:=2.5;
END IF;

log('Occurence number:'||v_occurence_no);
log('Multiplier:'||v_multiplier);
--Added for SR 441873 Ends
```

Replace with:

```sql
--Added for SR 441873 Starts
IF v_payroll_id = 181 THEN
   -- Tiered multiplier applies only for Cargo Payroll
   BEGIN
      SELECT COUNT(1) + 1
      INTO   v_occurence_no
      FROM   xxoa_early_late_deduction
      WHERE  person_id        = v_person_id
      AND    period_id        = p_period_id
      AND    TRUNC(punch_date) < TRUNC(v_date)
      AND    transaction_type = 'LATE_COMING';
   EXCEPTION
      WHEN OTHERS THEN
         v_occurence_no := 1;
   END;

   IF v_occurence_no <= 2 THEN
      v_multiplier := 0;
   ELSIF v_occurence_no <= 3 THEN
      v_multiplier := 1;
   ELSIF v_occurence_no <= 4 THEN
      v_multiplier := 1.5;
   ELSIF v_occurence_no <= 5 THEN
      v_multiplier := 2;
   ELSE
      v_multiplier := 2.5;
   END IF;

   log('Cargo Payroll - Occurence number : ' || v_occurence_no);
   log('Cargo Payroll - Multiplier       : ' || v_multiplier);

ELSE
   -- Non-Cargo Payroll: standard deduction, multiplier = 1 always
   v_occurence_no := NULL;
   v_multiplier   := 1;
   log('Non-Cargo Payroll - Standard multiplier applied : ' || v_multiplier);
END IF;
--Added for SR 441873 Ends
```

---

### Step 4 — The amount formula stays the same

No change needed here — it already uses `v_multiplier`:

```sql
v_amount := ROUND(
               (v_1_min_basic_sal
                * v_start_time_diff
                * v_multiplier)   --Added for SR 441873
            ,3);
```

For non-Cargo employees, `v_multiplier = 1` so the formula becomes:
```
amount = per_min_sal × minutes × 1
```
Which is exactly the original standard formula. No impact on existing behaviour.

