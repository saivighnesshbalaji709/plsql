  FUNCTION get_employee_group(
                              p_assignment_id  number
                             ,p_effective_date date
                             )
  RETURN VARCHAR2
  IS
    cursor cur_emp_group
    is
      select ppg.segment1 employee_group
        from per_all_people_f      pap
            ,per_all_assignments_f paa
            ,pay_people_groups     ppg
       where pap.person_id        = paa.person_id
         and paa.person_id        = paa.person_id
         and paa.people_group_id  = ppg.people_group_id
         and trunc(p_effective_date) between pap.effective_start_date and trunc(nvl(pap.effective_end_date,p_effective_date+1))
         and trunc(p_effective_date) between paa.effective_start_date and trunc(nvl(paa.effective_end_date,p_effective_date+1))
         and trunc(p_effective_date) between trunc(nvl(ppg.start_date_active,p_effective_date)) and trunc(nvl(ppg.end_date_active,p_effective_date+1))
         and pap.current_employee_flag = 'Y'
         and paa.assignment_type       = 'E'
         and paa.primary_flag          = 'Y'
         and paa.assignment_id         = p_assignment_id;

     rec_emp_group cur_emp_group%rowtype;
  BEGIN
     open  cur_emp_group;
     fetch cur_emp_group into rec_emp_group;
     close cur_emp_group;
     return (rec_emp_group.employee_group);
  exception
     when others then return null;
  END;

