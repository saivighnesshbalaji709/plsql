  FUNCTION get_udt_value(
                          p_effective_date   date
                         ,p_user_table_name  varchar2
                         ,p_user_column_name varchar2
                         ,p_user_row_name    varchar2
                         )
  return varchar2
  is
    cursor cur_udt
    is
      SELECT pci.value udt_value
        FROM pay_user_tables               put,
             pay_user_rows_f               pur,
             pay_user_columns              puc,
             pay_user_column_instances_f   pci
       WHERE put.user_table_id = puc.user_table_id
         AND put.user_table_id = pur.user_table_id
         AND pur.user_row_id = pci.user_row_id
         AND puc.user_column_id = pci.user_column_id
         AND trunc(p_effective_date) BETWEEN trunc(pur.effective_start_date) AND trunc(nvl(pur.effective_end_date, p_effective_date + 1))
         AND trunc(p_effective_date) BETWEEN trunc(pci.effective_start_date) AND trunc(nvl(pci.effective_end_date, p_effective_date + 1))
         AND put.user_table_name        = p_user_table_name
         AND puc.user_column_name       = p_user_column_name
         AND pur.row_low_range_or_name  = p_user_row_name;

     rec_udt cur_udt%rowtype;
  begin
      open  cur_udt;
      fetch cur_udt into rec_udt;
      close cur_udt;

      return (rec_udt.udt_value);
  exception
     when others then return null;
  end;

  FUNCTION get_rotation_plan(
                             p_assignment_id  number
                            ,p_effective_date date
                            ,p_return_type    varchar2
                            )
  RETURN VARCHAR2
  IS
    cursor cur_rot_plan
    is
      select to_char(haif.effective_start_date,'DD-MON-RRRR') rotation_plan_eff_dt
            ,hrp.name rotation_plan
            ,haif.attribute1 admin_exclude_flag
       from  per_all_people_f      pap
            ,per_all_assignments_f paa
            ,hxt_add_assign_info_f haif
            ,hxt_rotation_plans    hrp
      where pap.person_id      = paa.person_id
        and paa.assignment_id  = haif.assignment_id
        and haif.rotation_plan = hrp.id
        and trunc(p_effective_date) between pap.effective_start_date  and pap.effective_end_date
        and trunc(p_effective_date) between paa.effective_start_date  and paa.effective_end_date
        and trunc(p_effective_date) between haif.effective_start_date and haif.effective_end_date
        and paa.assignment_id = p_assignment_id;

     rec_rot_plan cur_rot_plan%rowtype;
  BEGIN

     open  cur_rot_plan;
     fetch cur_rot_plan into rec_rot_plan;
     close cur_rot_plan;

     if p_return_type = 'PLAN_NAME' then
        return (rec_rot_plan.rotation_plan);
     elsif p_return_type = 'PLAN_EFF_DATE' then
        return (rec_rot_plan.rotation_plan_eff_dt);
     elsif p_return_type = 'ADMIN_EXCLUDE_FLAG' then
        return (rec_rot_plan.admin_exclude_flag);
     end if;

  exception
     when others then return null;
  END;
