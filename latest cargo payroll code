   -- Added for SR 190134 :: START
    FUNCTION amount (
        p_assg_id            IN NUMBER,
        p_start_date         IN DATE,
        p_end_date           IN DATE,
        p_transaction_type   IN VARCHAR2
    ) RETURN NUMBER IS
        l_lceg_deduction_amount   NUMBER;
    BEGIN
            SELECT NVL(amount_deducted,0)
            INTO l_lceg_deduction_amount
            FROM
              (SELECT
                SUM(xeld.amount_deducted) amount_deducted
            FROM
                xxoa_early_late_deduction xeld,
                per_all_assignments_f paaf
            WHERE
                    1 = 1
                AND trunc(punch_date) BETWEEN paaf.effective_start_date AND paaf.effective_end_date
                AND paaf.primary_flag = 'Y'
                AND paaf.person_id = xeld.person_id
                AND xeld.punch_date >= p_start_date
                AND xeld.punch_date <= p_end_date
                AND xeld.transaction_type = p_transaction_type
                AND paaf.assignment_id = p_assg_id);

            RETURN l_lceg_deduction_amount;
    EXCEPTION
        WHEN no_data_found THEN
            RETURN 0;
        WHEN too_many_rows THEN
            RETURN 0;
        WHEN OTHERS THEN
            RETURN 0;
    END amount;
