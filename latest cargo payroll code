                                     )
 return varchar2
  IS
    cursor cur_adm_plan(p_payroll_name varchar2,p_rotation_plan varchar2,p_rotation_plan_eff_date date)
    is
      select count(*) from
          (
          SELECT puc.user_column_name payroll_name
                ,pur.row_low_range_or_name
                ,pci.value admin_plan_name
              --  ,xxoa_hr_late_early_ded_rep_new.get_udt_value(p_punch_date,'XXOA_OTL_RAMADAN_POLICY','ROTATION_PLAN',pci.value) ramadan_plan_name commented For SR 226703
			    ,xxoa_hr_late_early_ded_rep_new.get_udt_value(p_punch_date,'XXOA_LE_OTL_RAMADAN_ROASTER',p_payroll_name||'-'||p_religion,pci.value) ramadan_plan_name--- Added for SR 226703
              --  ,xxoa_hr_late_early_ded_rep_new.get_rotation_plan(p_assignment_id,trunc((p_rotation_plan_eff_date)-1),'PLAN_NAME') previous_plan_name Commented For SR 226703
			  ,xxoa_hr_late_early_ded_rep_new.get_prev_rotation_plan(p_assignment_id,p_punch_date) previous_plan_name -- Added For SR 226703
            FROM pay_user_tables               put,
                 pay_user_rows_f               pur,
                 pay_user_columns              puc,
                 pay_user_column_instances_f   pci
           WHERE put.user_table_id = puc.user_table_id
             AND put.user_table_id = pur.user_table_id
             AND pur.user_row_id = pci.user_row_id
             AND puc.user_column_id = pci.user_column_id
             AND upper(put.user_table_name) = 'XXOA_FLEXITIME_VALIDATION_DETAILS'
             AND upper(pur.row_low_range_or_name) like 'ROTATION PLAN %'
             AND trunc(p_punch_date) BETWEEN trunc(pur.effective_start_date) AND trunc(nvl(pur.effective_end_date, trunc(p_punch_date) + 1))
             AND trunc(p_punch_date) BETWEEN trunc(pci.effective_start_date) AND trunc(nvl(pci.effective_end_date, trunc(p_punch_date) + 1))
             AND puc.user_column_name = p_payroll_name
          )
          where (admin_plan_name = p_rotation_plan)
                 or
                (ramadan_plan_name = p_rotation_plan and previous_plan_name = admin_plan_name);

    cursor cur_emp_group(p_payroll_name varchar2,p_employee_group_name varchar2)
    is
           select count(*)
            FROM pay_user_tables               put,
                 pay_user_rows_f               pur,
                 pay_user_columns              puc,
                 pay_user_column_instances_f   pci
           WHERE put.user_table_id = puc.user_table_id
             AND put.user_table_id = pur.user_table_id
             AND pur.user_row_id = pci.user_row_id
             AND puc.user_column_id = pci.user_column_id
             AND upper(put.user_table_name) = 'XXOA_FLEXITIME_VALIDATION_DETAILS'
             AND upper(pur.row_low_range_or_name) like 'EMPLOYEE GROUP %'
             AND trunc(p_punch_date) BETWEEN trunc(pur.effective_start_date) AND trunc(nvl(pur.effective_end_date, trunc(p_punch_date) + 1))
             AND trunc(p_punch_date) BETWEEN trunc(pci.effective_start_date) AND trunc(nvl(pci.effective_end_date, trunc(p_punch_date) + 1))
             AND puc.user_column_name = p_payroll_name
             AND pci.value            = p_employee_group_name;

     lc_payroll_name          varchar2(80);
     lc_flexi_cutover_date    varchar2(12);
     lc_employee_group        varchar2(60);
     ln_admin_plan_cnt        number;
     ln_emp_flexi_group_cnt   number;
     lc_rotation_plan         varchar2(80);
     lc_rotation_plan_eff_dt  varchar2(12);
     ld_rotation_plan_eff_dt  date;
     lc_admin_exclusion_flag  varchar2(1);

  BEGIN
       lc_payroll_name          := xxoa_hr_late_early_ded_rep_new.get_payroll_name(p_assignment_id,p_punch_date);
       lc_flexi_cutover_date    := xxoa_hr_late_early_ded_rep_new.get_udt_value(p_punch_date,'XXOA_FLEXITIME_VALIDATION_DETAILS',lc_payroll_name,'Flexitime Cutover Date');
       lc_employee_group        := xxoa_hr_late_early_ded_rep_new.get_employee_group(p_assignment_id,p_punch_date);
       lc_rotation_plan         := xxoa_hr_late_early_ded_rep_new.get_rotation_plan(p_assignment_id,p_punch_date,'PLAN_NAME');
       lc_rotation_plan_eff_dt  := xxoa_hr_late_early_ded_rep_new.get_rotation_plan(p_assignment_id,p_punch_date,'PLAN_EFF_DATE');
       lc_admin_exclusion_flag  := xxoa_hr_late_early_ded_rep_new.get_rotation_plan(p_assignment_id,p_punch_date,'ADMIN_EXCLUDE_FLAG');

       if lc_rotation_plan_eff_dt is not null then
          ld_rotation_plan_eff_dt := trunc(to_date(lc_rotation_plan_eff_dt,'DD-MON-RRRR'));
       end if;

       IF lc_admin_exclusion_flag = 'Y' then
           return ('N');
       ELSIF lc_flexi_cutover_date is null then
          return ('N');
       ELSIF lc_flexi_cutover_date is not null and to_date(lc_flexi_cutover_date,'DD-MON-RRRR') > trunc(p_punch_date) then
          return ('N');
       ELSE
           open cur_emp_group(lc_payroll_name,lc_employee_group);
           fetch cur_emp_group into ln_emp_flexi_group_cnt;
           close cur_emp_group;

           if ln_emp_flexi_group_cnt = 0 then
              return ('N');
           else
               open  cur_adm_plan(lc_payroll_name,lc_rotation_plan,ld_rotation_plan_eff_dt);
               fetch cur_adm_plan into ln_admin_plan_cnt;
               close cur_adm_plan;

               if ln_admin_plan_cnt = 0 then
                  return ('N');
               else
                  return ('Y');
               end if;
           end if;
       END IF;
  EXCEPTION
    WHEN OTHERS THEN
    RETURN ('N');
  END;

  function get_flexi_late_early_dtls(
                                      p_assignment_id          number
                                     ,p_punch_date             date
                                     ,p_shift_in_time          date
                                     ,p_shift_out_time         date
                                     ,p_punch_in_time          date
                                     ,p_punch_out_time         date
                                     ,p_return_type            varchar2
                                   )
  return varchar2
  is
    lc_payroll_name         varchar2(80);
    lc_flexi_cutover_date   varchar2(80);
    lc_flexi_late_mins      varchar2(80);
    lc_flexi_early_mins     varchar2(80);
    ld_flexi_shift_in_time  date;
    ld_flexi_shift_out_time date;
    lc_time_in_status       varchar2(30);
    ln_total_shift_hours    number;
    ln_total_punch_hours    number;
    lc_shift_completed_yn   varchar2(1);
    lc_late_deduction_yn    varchar2(1)  := 'N';
    lc_early_deduction_yn   varchar2(1)  := 'N';
    lc_late_deduction_mins  number       := 0;
    lc_early_deduction_mins number       := 0;
  begin
    log('<-------get_flexi_late_early_dtls starts------>');
    log('lc_late_deduction_yn             -->'||p_assignment_id);
    log('lc_late_deduction_yn             -->'||to_char(p_punch_date,'DD-MON-RRRR HH24:MI:SS'));
    log('p_shift_in_time                  -->'||to_char(p_shift_in_time,'DD-MON-RRRR HH24:MI:SS'));
    log('p_shift_out_time                 -->'||to_char(p_shift_out_time,'DD-MON-RRRR HH24:MI:SS'));
    log('p_punch_in_time                  -->'||to_char(p_punch_in_time,'DD-MON-RRRR HH24:MI:SS'));
    log('p_punch_out_time                 -->'||to_char(p_punch_out_time,'DD-MON-RRRR HH24:MI:SS'));
    lc_payroll_name       := xxoa_hr_late_early_ded_rep_new.get_payroll_name(p_assignment_id,p_punch_date);
    lc_flexi_cutover_date := xxoa_hr_late_early_ded_rep_new.get_udt_value(p_punch_date,'XXOA_FLEXITIME_VALIDATION_DETAILS',lc_payroll_name,'Flexitime Cutover Date');
    lc_flexi_late_mins    := xxoa_hr_late_early_ded_rep_new.get_udt_value(p_punch_date,'XXOA_FLEXITIME_VALIDATION_DETAILS',lc_payroll_name,'Flexitime Late Mins');
    lc_flexi_early_mins   := xxoa_hr_late_early_ded_rep_new.get_udt_value(p_punch_date,'XXOA_FLEXITIME_VALIDATION_DETAILS',lc_payroll_name,'Flexitime Early Mins');
    log('lc_payroll_name                  -->'||lc_payroll_name);
    log('lc_flexi_cutover_date            -->'||lc_flexi_cutover_date);
    log('lc_flexi_late_mins               -->'||lc_flexi_late_mins);
    log('lc_flexi_early_mins              -->'||lc_flexi_early_mins);
    ld_flexi_shift_in_time  := p_shift_in_time  + (lc_flexi_late_mins/1440);
    ld_flexi_shift_out_time := p_shift_out_time + (lc_flexi_early_mins/1440);
    log('ld_flexi_shift_in_time           -->'||to_char(ld_flexi_shift_in_time,'DD-MON-RRRR HH24:MI:SS'));
    log('ld_flexi_shift_out_time          -->'||to_char(ld_flexi_shift_out_time,'DD-MON-RRRR HH24:MI:SS'));
    ln_total_shift_hours := (p_shift_out_time - p_shift_in_time)*24;
    ln_total_punch_hours := (p_punch_out_time - p_punch_in_time)*24;
    log('ln_total_shift_hours             -->'||ln_total_shift_hours);
    log('ln_total_punch_hours             -->'||ln_total_punch_hours);
    if p_punch_in_time = p_shift_in_time then
       lc_time_in_status := 'ON TIME';
    elsif p_punch_in_time between p_shift_in_time and ld_flexi_shift_in_time then
       lc_time_in_status := 'FLEXI';
    elsif p_punch_in_time > ld_flexi_shift_in_time then
       lc_time_in_status := 'LATE';
    end if;
    log('lc_time_in_status                -->'||lc_time_in_status);
    if ln_total_punch_hours >= ln_total_shift_hours then
       lc_shift_completed_yn := 'Y';
    else
       lc_shift_completed_yn := 'N';
    end if;
    log('lc_shift_completed_yn            -->'||lc_shift_completed_yn);
    if lc_time_in_status = 'ON TIME' and lc_shift_completed_yn = 'N' and p_punch_out_time < p_shift_out_time then
       lc_late_deduction_yn     := 'N';
       lc_early_deduction_yn    := 'Y';
       lc_late_deduction_mins   := 0;
       lc_early_deduction_mins  := round((p_shift_out_time - p_punch_out_time)*24*60);
       log('Flexi Scenario 1 --->'||'lc_time_in_status-->'||lc_time_in_status||' ,lc_shift_completed_yn-->'||lc_shift_completed_yn
       ||' ,Punch Out Time less than Shift Out Time');
    elsif lc_time_in_status = 'FLEXI' and lc_shift_completed_yn = 'N' and p_punch_out_time >= p_shift_out_time then
       lc_late_deduction_yn     := 'Y';
       lc_early_deduction_yn    := 'N';
       lc_late_deduction_mins   := round((ln_total_shift_hours - ln_total_punch_hours)*60);
       lc_early_deduction_mins  := 0;
       log('Flexi Scenario 2 --->'||'lc_time_in_status-->'||lc_time_in_status||' ,lc_shift_completed_yn-->'||lc_shift_completed_yn
       ||' ,Punch Out Time Greater than or equal to Shift Out Time');
    elsif lc_time_in_status = 'FLEXI' and lc_shift_completed_yn = 'N' and p_punch_out_time < p_shift_out_time then
       lc_late_deduction_yn     := 'Y';
       lc_early_deduction_yn    := 'Y';
       lc_late_deduction_mins   := round((p_punch_in_time - p_shift_in_time)*24*60);
       lc_early_deduction_mins  := round((p_shift_out_time - p_punch_out_time)*24*60);
       log('Flexi Scenario 3 --->'||'lc_time_in_status-->'||lc_time_in_status||' ,lc_shift_completed_yn-->'||lc_shift_completed_yn
       ||' ,Punch Out Time less than Shift Out Time');
    elsif lc_time_in_status = 'LATE' and lc_shift_completed_yn = 'Y' then
       lc_late_deduction_yn     := 'Y';
       lc_early_deduction_yn    := 'N';
       lc_late_deduction_mins   := round((p_punch_in_time - ld_flexi_shift_in_time)*24*60);
       lc_early_deduction_mins  := 0;
       log('Flexi Scenario 4 --->'||'lc_time_in_status-->'||lc_time_in_status||' ,lc_shift_completed_yn-->'||lc_shift_completed_yn);
    elsif lc_time_in_status = 'LATE' and lc_shift_completed_yn = 'N' and p_punch_out_time >= ld_flexi_shift_out_time then
       lc_late_deduction_yn     := 'Y';
       lc_early_deduction_yn    := 'N';
       lc_late_deduction_mins   := round((p_punch_in_time - ld_flexi_shift_in_time)*24*60);
       lc_early_deduction_mins  := 0;
       log('Flexi Scenario 5 --->'||'lc_time_in_status-->'||lc_time_in_status||' ,lc_shift_completed_yn-->'||lc_shift_completed_yn
       ||' ,Punch Out Time Greater than or equal to Flexi Shift Out Time');
    elsif lc_time_in_status = 'LATE' and lc_shift_completed_yn = 'N' and p_punch_out_time < ld_flexi_shift_out_time then
       lc_late_deduction_yn     := 'Y';
       lc_early_deduction_yn    := 'Y';
       lc_late_deduction_mins   := round((p_punch_in_time - ld_flexi_shift_in_time)*24*60);
       lc_early_deduction_mins  := round((ld_flexi_shift_out_time - p_punch_out_time)*24*60);
       log('Flexi Scenario 6 --->'||'lc_time_in_status-->'||lc_time_in_status||' ,lc_shift_completed_yn-->'||lc_shift_completed_yn
       ||' ,Punch Out Time less than Flexi Shift Out Time');
    end if;

    log('lc_late_deduction_yn--->'||lc_late_deduction_yn);
    log('lc_early_deduction_yn--->'||lc_early_deduction_yn);
    log('lc_late_deduction_mins--->'||lc_late_deduction_mins);
    log('lc_early_deduction_mins--->'||lc_early_deduction_mins);

    if p_return_type = 'LATE_DEDUCTION_YN' then
       return (lc_late_deduction_yn);
    elsif p_return_type = 'EARLY_DEDUCTION_YN' then
       return (lc_early_deduction_yn);
    elsif p_return_type = 'LATE_DEDUCTION_MINS' then
       return (lc_late_deduction_mins);
    elsif p_return_type = 'EARLY_DEDUCTION_MINS' then
       return (lc_early_deduction_mins);
    end if;
   log('<-------get_flexi_late_early_dtls ends------>');
  exception
    when others then
		if p_return_type = 'LATE_DEDUCTION_YN' then
		   return ('N');
		elsif p_return_type = 'EARLY_DEDUCTION_YN' then
		   return ('N');
		elsif p_return_type = 'LATE_DEDUCTION_MINS' then
		   return (0);
		elsif p_return_type = 'EARLY_DEDUCTION_MINS' then
		   return (0);
		end if;
  end;
--SR-211619 Ends
END xxoa_hr_late_early_ded_rep_new;
