      v_sh_start_time_st_dt    DATE;
      v_sh_stop_time_st_dt     DATE;
      v_act_start_time_st_dt   DATE;
      v_act_stop_time_st_dt    DATE;
      v_1_min_basic_sal        NUMBER;
      v_total_shift_hours      NUMBER;
      v_total_actual_hours     NUMBER;
      v_deduction_flag         VARCHAR2 (1);
      l_flag                   VARCHAR2 (1);
      v_employee_number        VARCHAR2 (140);
      v_record_exist           NUMBER;
      v_insert                 VARCHAR2 (1);
      v_occurence_rep          NUMBER;
   ---
      lc_admin_plan_yn          varchar2(1);         --Added for SR-211619
      lc_late_deduction_yn      varchar2(1);         --Added for SR-211619
      lc_late_deduction_mins    number;              --Added for SR-211619
      lc_calculation_type       varchar2(30);        --Added for SR-211619
	  c_chk_shift				NUMBER;--Added for SR 398109
	  v_occurence_no            NUMBER;  --Added for SR 441873
	  v_multiplier              NUMBER; --Added for SR 441873
   BEGIN
      v_date            := p_start_date;
      v_count           := 0;
      v_occurence       := 1;
      v_occurence_rep   := 0;
      v_basic_sal       := 0;
      v_msg             := ' ';
      LOOP
         EXIT WHEN v_date > p_end_date;
         v_amount   := 0;
         --Added for SR-211619 Starts
         lc_admin_plan_yn := xxoa_hr_late_early_ded_rep_new.is_admin_rotation_plan_yn(p_assignment_id,v_date,p_religion);  --- Added for SR 226703
         log('lc_admin_plan_yn-->'||lc_admin_plan_yn);
         if lc_admin_plan_yn = 'Y' then
            lc_calculation_type := 'FLEXI';
         elsif lc_admin_plan_yn = 'N' then
            lc_calculation_type := 'GRACE';
         end if;
         log('lc_calculation_type-->'||lc_calculation_type);
         --Added for SR-211619 Ends
         /*=================*/
         /*Derive Person Id */
         /*=================*/
         BEGIN


            SELECT papf.person_id
                  ,papf.employee_number
            INTO   v_person_id
                  ,v_employee_number
            FROM   per_all_people_f papf
                  ,per_all_assignments_f paaf
				  ,per_grades pg ,per_jobs pj --added job and grade details for SR 427279
            WHERE  1 = 1
            AND    papf.person_id = paaf.person_id
            AND    paaf.assignment_id = p_assignment_id
            AND    paaf.primary_flag = 'Y'
            AND    v_date BETWEEN papf.effective_start_date
                              AND papf.effective_end_date
            AND    v_date BETWEEN paaf.effective_start_date
                              AND paaf.effective_end_date
			and   paaf.job_id = pj.job_id
            and   paaf.grade_id = pg.grade_id
            AND    v_date between pg.date_from  and nvl(pg.date_to,to_date('31-Dec-4712'))
            AND    v_date between pj.date_from  and nvl(pj.date_to,to_date('31-Dec-4712'))
	        /* Commented For SR 177751 :: START
            AND    EXISTS
                      (SELECT 1
                       FROM   fnd_lookup_values_vl
                       WHERE  lookup_type = 'XXOA_RUN_LATE_EARLY_DEDUCT_ORG'
                       AND    enabled_flag = 'Y'
                       AND    meaning =
                                 (SELECT name
                                  FROM   hr_all_organization_units
                                  WHERE  TYPE = 'SE'
                                  AND    organization_id =
                                            paaf.organization_id))
			Commented For SR 177751 :: END */
            AND   NOT  EXISTS
                      (SELECT 1
                       FROM   fnd_lookup_values_vl
                       WHERE  lookup_type = 'XXOA_EXCLUD_LATE_EARLY_SECTION'
                       AND    enabled_flag = 'Y'
                       AND    meaning =
                                 (SELECT name
                                  FROM   hr_all_organization_units
                                  WHERE  TYPE = 'SE'
                                  AND    organization_id =
                                            paaf.organization_id)
                      --  and lc_admin_plan_yn = 'N' --Added for SR-211619 Commented For 223979
                        )
			-- Added for SR 177751 :: END
            AND    NOT EXISTS
                          (SELECT 1
                           FROM   fnd_lookup_values_vl
                           WHERE  lookup_type =
                                     'XXOA_EXCLUDE_LATE_EARLY_DEDUCT'
                           AND    enabled_flag = 'Y'
                           AND    meaning = papf.employee_number
                         --  and lc_admin_plan_yn = 'N'                        --Added for SR-211619  Commented For 223979
                           )
						   ----added for SR427279------
			AND    NOT EXISTS
                          (SELECT 1
                           FROM   fnd_lookup_values_vl
                           WHERE  lookup_type =
                                     'XXOA_EXCL_JOB_LATE_EARLY_DED'
                           AND    enabled_flag = 'Y'
                           AND    meaning = pj.name
						    AND v_date BETWEEN start_date_active
								AND NVL(end_date_active,'31-DEC-4712')
                           )
			AND    NOT EXISTS
                          (SELECT 1
                           FROM   fnd_lookup_values_vl
                           WHERE  lookup_type =
                                     'XXOA_EXCL_GRADE_LATE_EARLY_DED'
                           AND    enabled_flag = 'Y'
                           AND    meaning = pg.name
						   AND v_date BETWEEN start_date_active
								AND NVL(end_date_active,'31-DEC-4712')
                           );
							  ----END : added for SR427279------

         EXCEPTION
            WHEN NO_DATA_FOUND
            THEN
               v_person_id   := NULL;
            WHEN TOO_MANY_ROWS
            THEN
               v_person_id   := NULL;
            WHEN OTHERS
            THEN
               v_person_id   := NULL;
         END;
         log ('v_person_id : ' || v_person_id);
         IF v_person_id IS NOT NULL
         THEN
            /*====================================*/
            /*Derive Shift Name and Holiday Count */
            /*====================================*/
            v_shift_name       := xxoa_otl_get_shift_name_fns (v_person_id
                                                              ,v_date
                                                              ,'NAME');
            v_holiday_cnt      := xxoa_otl_check_holiday_fns (v_person_id
                                                             ,v_date);
            log ('v_shift_name : ' || v_shift_name);
            log ('v_holiday_cnt: ' || v_holiday_cnt);
		----added for SR 398109---
		Begin
        c_chk_shift:=0;
         SELECT count(1) into c_chk_shift
         FROM apps.fnd_lookup_values_vl flv
         WHERE flv.lookup_type = 'XXOA_OTL_LATE_EARLY_SHIFT_EXCL'
         AND flv.enabled_flag  ='Y'
         AND v_date BETWEEN flv.start_date_active
         AND NVL(flv.end_date_active,'31-DEC-4712')
         AND Upper(Meaning) = Upper(v_shift_name);
         Exception when others then
         c_chk_shift:=0;
        End;

		 log ('c_chk_shift: ' || c_chk_shift);
----End for SR 398109---

       --     IF UPPER (v_shift_name) NOT LIKE '%OFF%' AND v_holiday_cnt = 0 ----commented for SR 398109
			IF c_chk_shift <> 1  AND v_holiday_cnt = 0 ----added for SR 398109
            THEN
               /*================================*/
               /*Derive Shift Start And End Time */
               /*================================*/
               v_sh_start_time_st_dt      := TO_DATE (
                                                TO_CHAR (v_date
                                                        ,'MM/DD/RRRR')
                                                || LPAD (
                                                      xxoa_otl_get_shift_name_fns (
                                                         v_person_id
                                                        ,v_date
                                                        ,'START_TIME')
                                                     ,'4'
                                                     ,'0')
                                               ,'MM/DD/RRRRHH24MI');
               v_sh_stop_time_st_dt       := TO_DATE (
                                                TO_CHAR (v_date
                                                        ,'MM/DD/RRRR')
                                                || LPAD (
                                                      xxoa_otl_get_shift_name_fns (
                                                         v_person_id
                                                        ,v_date
                                                        ,'STOP_TIME')
                                                     ,'4'
                                                     ,'0')
                                               ,'MM/DD/RRRRHH24MI');
               v_sh_start_time_st         := LPAD (
                                                xxoa_otl_get_shift_name_fns (
                                                   v_person_id
                                                  ,v_date
                                                  ,'START_TIME')
                                               ,'4'
                                               ,'0');
               v_sh_stop_time_st          := LPAD (
                                                xxoa_otl_get_shift_name_fns (
                                                   v_person_id
                                                  ,v_date
                                                  ,'STOP_TIME')
                                               ,'4'
                                               ,'0');
               /* Added logic by transsys to get correct stop time */
               IF v_sh_start_time_st_dt > v_sh_stop_time_st_dt
               THEN
                  v_sh_stop_time_st_dt   := v_sh_stop_time_st_dt + 1;
               /*      TO_DATE (   TO_CHAR (v_date + 1, 'MM/DD/RRRR')
                              || LPAD (xxoa_otl_get_shift_name_fns (v_person_id,
                                                                    v_date + 1,
                                                                    'STOP_TIME'
                                                                   ),
                                       '4',
                                       '0'
                                      ),
                              'MM/DD/RRRRHH24MI'
                             );  */
               END IF;
               /* Added logic by Transsys to get correct stop time */
               log ('v_sh_start_time_st_dt : ' || v_sh_start_time_st_dt);
               log ('v_sh_stop_time_st_dt : ' || v_sh_stop_time_st_dt);
               log ('v_sh_start_time_st : ' || v_sh_start_time_st);
               log ('v_sh_stop_time_st : ' || v_sh_stop_time_st);
               /*=====================================*/
               /*Derive the Actual start and end Time */
               /*=====================================*/
               BEGIN
                  v_act_start_time_st   := '0';
                  v_act_stop_time_st    := '0';
                  SELECT LPAD (TO_CHAR (MIN (xxtc.start_time)
                                       ,'HH24MI')
                              ,'4'
                              ,'0')
                        ,LPAD (TO_CHAR (MAX (xxtc.stop_time)
                                       ,'HH24MI')
                              ,'4'
                              ,'0')
                        ,MIN (xxtc.start_time)
                        ,MAX (xxtc.stop_time)
                  INTO   v_act_start_time_st
                        ,v_act_stop_time_st
                        ,v_act_start_time_st_dt
                        ,v_act_stop_time_st_dt
                  FROM   xxoa_otl_time_card_detail_v xxtc
                  WHERE  1 = 1
                  AND    xxtc.resource_id = v_person_id
                  AND    TRUNC (xxtc.punch_date) = v_date
                  AND    xxtc.approval_status = 'APPROVED';
               EXCEPTION
                  WHEN OTHERS
                  THEN
                     v_act_start_time_st      := '0';
                     v_act_stop_time_st       := '0';
                     v_act_start_time_st_dt   := NULL;
                     v_act_stop_time_st_dt    := NULL;
               END;
               log ('v_act_start_time_st : ' || v_act_start_time_st);
               log ('v_act_stop_time_st : ' || v_act_stop_time_st);
               log ('v_act_start_time_st_dt : ' || v_act_start_time_st_dt);
               log ('v_act_stop_time_st_dt : ' || v_act_stop_time_st_dt);
               /*===========================*/
               /*Derive Total Working Hours */
               /*===========================*/
               v_total_shift_hours        := 24
                                             * (v_sh_stop_time_st_dt
                                                - v_sh_start_time_st_dt);
               v_total_actual_hours       := 24
                                             * (v_act_stop_time_st_dt
                                                - v_act_start_time_st_dt);
               log ('v_total_shift_hours : ' || v_total_shift_hours);
               log ('v_total_actual_hours : ' || v_total_actual_hours);
               /*==============================*/
               /*Convert Shift Start in minutes*/
               /*==============================*/
               IF v_sh_start_time_st = '0'
               THEN
                  v_sh_start_time   := 0;
               ELSE
                  v_sh_start_time      := (SUBSTR (v_sh_start_time_st
                                                  ,1
                                                  ,2)
                                           * 60)
                                          + SUBSTR (v_sh_start_time_st
                                                   ,-2);
               END IF;
               log ('v_sh_start_time : ' || v_sh_start_time);
               /*===============================*/
               /*Convert Actual Start in minutes*/
               /*===============================*/
               IF v_act_start_time_st = '0'
               THEN
                  v_act_start_time   := 0;
               ELSE
                  v_act_start_time      := (SUBSTR (v_act_start_time_st
                                                   ,1
                                                   ,2)
                                            * 60)
                                           + SUBSTR (v_act_start_time_st
                                                    ,-2);
               END IF;
               log ('v_act_start_time : ' || v_act_start_time);
               /*==========================================================*/
               /*Calcualte the time difference between actual and scheduled*/
               /*==========================================================*/


               --Commented by Transsys to handle cases having shift start time 00:00 and employee comes early ex 23:50
               /*
               IF v_act_start_time = 0
               THEN
                  v_start_time_diff   := 9999;
               ELSE
                  v_start_time_diff   := v_act_start_time - v_sh_start_time;
               END IF;*/

               v_start_time_diff   := abs(v_act_start_time - v_sh_start_time);

               log ('v_start_time_diff : ' || v_start_time_diff);


               /*=================================================*/
               /*Global Values for Grace Time and allowed Attempts*/
               /*=================================================*/
               BEGIN
                  SELECT global_value
                  INTO   v_grace_time
                  FROM   ff_globals_f
                  WHERE  global_name = 'XXOA_LATE_COME_GRACE_TIME'
                  AND    SYSDATE BETWEEN effective_start_date
                                     AND effective_end_date
                  AND    business_group_id =
                            fnd_profile.VALUE ('PER_BUSINESS_GROUP_ID');
               END;
               BEGIN
                  SELECT global_value
                  INTO   v_grace_attempt
                  FROM   ff_globals_f
                  WHERE  global_name = 'XXOA_LATE_COME_GRACE_ATTEMPT'
                  AND    SYSDATE BETWEEN effective_start_date
                                     AND effective_end_date
                  AND    business_group_id =
                            fnd_profile.VALUE ('PER_BUSINESS_GROUP_ID');
               END;
               dbms ('v_grace_time : ' || v_grace_time);
               dbms ('v_grace_attempt : ' || v_grace_attempt);
			   log ('v_grace_time : ' || v_grace_time); --Added for SR#441873
               log ('v_grace_attempt : ' || v_grace_attempt); --Added for SR#441873
               /*==========================*/
               /*Basic Salary For a Minut */
               /*=========================*/
               v_basic_sal                := xxoa_payroll_all.
                                              get_basic_salary (
                                                p_bg_id
                                               ,p_assignment_id
                                               ,v_date);
               v_days                     :=   TRUNC (LAST_DAY (p_end_date))
                                             - TRUNC (p_end_date
                                                     ,'MM')
                                             + 1;
               v_1_min_basic_sal          := (v_basic_sal * 12)
                                             / (60
                                                * (240 * v_total_shift_hours));
               dbms ('v_basic_sal : ' || v_basic_sal);
               dbms ('v_days : ' || v_days);
               dbms ('v_1_min_basic_sal : ' || v_1_min_basic_sal);
			   log ('v_basic_sal : ' || v_basic_sal); --Added for SR#441873
               log ('v_days : ' || v_days); --Added for SR#441873
               log ('v_1_min_basic_sal : ' || v_1_min_basic_sal); --Added for SR#441873
               /*===============================*/
               /*Derive Conditions as per policy*/
               /*===============================*/
               /* Commented by Venkat on 18 Dec 2015
               IF v_act_start_time_st_dt > v_sh_start_time_st_dt
               THEN
                  v_occurence_rep   := v_occurence_rep + 1;
                  dbms ('v_occurence_rep : ' || v_occurence_rep);
                  LOG ('v_occurence_rep : ' || v_occurence_rep);
                  IF v_start_time_diff <= v_grace_time
                  THEN
                     IF v_occurence > v_grace_attempt
                     THEN
                        v_deduction_flag   := 'Y';
                     ELSE
                        IF v_total_actual_hours >= v_total_shift_hours
                        THEN
                           v_deduction_flag   := 'N';
                           dbms ('v_occurence : ' || v_occurence);
                           LOG ('v_occurence : ' || v_occurence);
                           v_occurence        := v_occurence + 1;
                        ELSE
                           v_deduction_flag   := 'Y';
                        END IF;
                     END IF;
                  ELSE
                     v_deduction_flag   := 'Y';
                  END IF;
                  dbms ('v_deduction_flag : ' || v_deduction_flag);
                  LOG ('v_deduction_flag : ' || v_deduction_flag);
                 Commented by Venkat */
                 /* Added by Venkat to fix Late coming Grace Issue */
                 IF (
                     (v_act_start_time_st_dt > v_sh_start_time_st_dt and lc_admin_plan_yn = 'N')        --Added for SR-211619
                      or                                                                                --Added for SR-211619
                     (v_act_start_time_st_dt >= v_sh_start_time_st_dt and lc_admin_plan_yn = 'Y')       --Added forSR-211619
                     )
               THEN
                  --v_occurence_rep := v_occurence_rep + 1;           --Commented for SR-211619
                  --dbms ('v_occurence_rep : ' || v_occurence_rep);   --Commented for SR-211619
    --Added for SR-211619 Starts
                 if lc_admin_plan_yn = 'Y' then
                    lc_late_deduction_yn := xxoa_hr_late_early_ded_rep_new.get_flexi_late_early_dtls(p_assignment_id,v_date
                                                                                                    ,v_sh_start_time_st_dt,v_sh_stop_time_st_dt
                                                                                                    ,v_act_start_time_st_dt,v_act_stop_time_st_dt
                                                                                                    ,'LATE_DEDUCTION_YN'
                                                                                                    );
                    v_deduction_flag := lc_late_deduction_yn;
                    if v_deduction_flag = 'Y' then
                      v_occurence_rep := v_occurence_rep + 1;
                      dbms ('v_occurence_rep : ' || v_occurence_rep);
					  log ('v_occurence_rep : ' || v_occurence_rep); --Added for SR#441873
                    end if;

                 elsif lc_admin_plan_yn = 'N' then
                      v_occurence_rep := v_occurence_rep + 1;
                      dbms ('v_occurence_rep : ' || v_occurence_rep);
					  log ('v_occurence_rep : ' || v_occurence_rep); --Added for SR#441873
    --Added for SR-211619 Ends
                  IF v_start_time_diff <= v_grace_time
                  THEN
                     IF v_occurence > v_grace_attempt
                     THEN
                        v_deduction_flag := 'Y';
                     ELSE
                        IF v_total_actual_hours >= v_total_shift_hours
                        THEN
                           v_deduction_flag := 'N';
                           dbms ('v_occurence : ' || v_occurence);
                           v_occurence := v_occurence + 1;
                        ELSE
                           v_deduction_flag := 'Y';
                        END IF;
                     END IF ;
                  ELSE
                     v_deduction_flag := 'Y';
                  END IF;
               end if;          --Added for SR-211619
/*=============================================*/
/*  Derive Conditions as per policy           */
/*On Leave Date if Emp is late/Early going  */
/*then there should not be any deduction*/
/*=============================================*/
/* Added By Sameer Patil(ACL) Start here */
                  BEGIN
                     SELECT 'Y'
                       INTO l_flag
                       FROM per_absence_attendances a
                      WHERE a.person_id = v_person_id
                        AND TRUNC (v_date) BETWEEN TRUNC (a.date_start)
                                               AND TRUNC (a.date_end);
                  EXCEPTION
                     WHEN OTHERS
                     THEN
                        l_flag := 'N';
                  END;

                  IF l_flag = 'Y'
                  THEN
                     v_deduction_flag := 'N';
                  END IF;
                 /* Added by Venkat to fix Late coming Grace Issue */
                 log('v_deduction_flag-->'||v_deduction_flag);
                 
                    --Added for SR 441873 Starts
					 BEGIN
                     SELECT COUNT (1) + 1
                     INTO   v_occurence_no
                     FROM   xxoa_early_late_deduction
                     WHERE  person_id = v_person_id
					 AND    period_id = p_period_id
                     AND    TRUNC (punch_date) < TRUNC (v_date)
                     AND    transaction_type = 'LATE_COMING';
					 EXCEPTION
					   WHEN OTHERS THEN
					        v_occurence_no :=1;	
                     END;
					 
					 IF v_occurence_no <= 2 THEN
					    v_multiplier:=0;
					 ELSIF v_occurence_no <= 3 THEN
					    v_multiplier:=1;
					 ELSIF v_occurence_no <= 4 THEN
					    v_multiplier:=1.5;
					 ELSIF v_occurence_no <= 5 THEN
					    v_multiplier:=2;
					 ELSE
					    v_multiplier:=2.5;
					 END IF;	
						
					 log('Occurence number:'||v_occurence_no);
					 log('Multiplier:'||v_multiplier);
					 
					 --Added for SR 441873 Ends
                     
                     IF v_deduction_flag = 'N'
                     THEN
                     v_msg      :=    'Punch Date : '
                                   || TO_CHAR (v_date
                                              ,'DD-MON-RRRR')
                                   || ' Number of occurence : '
                                   || v_occurence_rep
                                   || ' Number of grace attempt used : '
                                   || v_occurence
                                   || ' Late by (Min) : '
                                   || v_start_time_diff
                                   || ' Amount Deducted : '
                                   || TO_CHAR (v_amount
                                              ,'99900.99')
                                   || ' Calculation Type : '       --Added for SR-211619
                                   || lc_calculation_type;         --Added for SR-211619
                     LOG (v_msg);
                     ELSIF v_deduction_flag = 'Y'
                     THEN
                     log('lc_admin_plan_yn-->'||lc_admin_plan_yn);
                     --Added for SR-211619 Starts
                      if lc_admin_plan_yn = 'Y' then
                          log('Inside admin block');
                          lc_late_deduction_mins := xxoa_hr_late_early_ded_rep_new.get_flexi_late_early_dtls(p_assignment_id,v_date
                                                                                                          ,v_sh_start_time_st_dt,v_sh_stop_time_st_dt
                                                                                                          ,v_act_start_time_st_dt,v_act_stop_time_st_dt
                                                                                                          ,'LATE_DEDUCTION_MINS'
                                                                                                          );
                           log('lc_late_deduction_mins-->'||lc_late_deduction_mins);
                           v_start_time_diff := abs(lc_late_deduction_mins);
                      end if;
                     --Added for SR-211619 Ends
					 
                     v_amount      := ROUND (
                                         (v_1_min_basic_sal
                                          * v_start_time_diff
										  * v_multiplier)        --Added for SR 441873
                                        ,3);
                     v_msg         :=    'Punch Date : '
                                      || TO_CHAR (v_date
                                                 ,'DD-MON-RRRR')
                                      || ' Number of occurence : '
                                      || v_occurence_rep
                                      || ' Number of grace attempt used : '
                                      || v_occurence
                                      || ' Late by (Min) : '
                                      || v_start_time_diff
                                      || ' Amount Deducted : '
                                      || TO_CHAR (v_amount
                                                 ,'99900.99')
                                      || ' Calculation Type : '       --Added for SR-211619
                                      || lc_calculation_type;         --Added for SR-211619
                     LOG (v_msg);
                  END IF;
                  dbms ('v_msg : ' || v_msg);
                  dbms ('v_amount : ' || v_amount);
                  v_record_exist    := 0;
                  v_insert          := 'N';
                  BEGIN
                     SELECT COUNT (1)
                     INTO   v_record_exist
                     FROM   xxoa_early_late_deduction
                     WHERE  person_id = v_person_id
                     AND    TRUNC (punch_date) = TRUNC (v_date)
                     AND    transaction_type = 'LATE_COMING';
                  END;
                  IF v_record_exist > 0
                  THEN
                     v_insert   := 'N';
                     LOG (
                           'Record Already Exist For Employee : '
                        || v_employee_number
                        || ' For Date : '
                        || v_date);
                  ELSE
                     IF ((lc_admin_plan_yn = 'Y' and v_deduction_flag = 'Y') or lc_admin_plan_yn = 'N') then    --Added for SR-211619
                         v_insert   := 'Y';
                     END IF;                                                                                        --Added for SR-211619
                  END IF;
                  IF v_insert = 'Y'
                  THEN
                     BEGIN
                        INSERT
                        INTO   xxoa_early_late_deduction (transaction_type
                                                         ,period_id
                                                         ,person_id
                                                         ,punch_date
                                                         ,sh_start_time
                                                         ,sh_end_time
                                                         ,act_start_time
                                                         ,act_end_time
                                                         ,late_hour_time_cnt
                                                         ,no_of_occurence
                                                         ,amount_deducted
                                                         ,MESSAGE
                                                         ,grace_attempt_used)
                        VALUES ('LATE_COMING'
                               ,p_period_id
                               ,v_person_id
                               ,v_date
                               ,v_sh_start_time_st
                               ,v_sh_stop_time_st
                               ,v_act_start_time_st
                               ,v_act_stop_time_st
                               ,v_start_time_diff
                               ,v_occurence_rep
                               ,v_amount
                               ,v_msg
                            --,v_occurence                                      --Commented for SR 190134
                               ,decode(lc_admin_plan_yn,'Y',0,v_occurence));    --Added for SR 190134
                        COMMIT;
                        LOG (
                              'Record Inserted For Employee : '
                           || v_employee_number
                           || ' For Punch Date : '
                           || v_date);
                     EXCEPTION
                        WHEN OTHERS
                        THEN
                           LOG (
                                 'Insert Record Faild For Employee : '
                              || v_employee_number
                              || ' For Punch Date : '
                              || v_date);
                     END;
                  END IF;
               END IF;
            END IF;
         END IF;
         v_date     := v_date + 1;
      END LOOP;
      p_msg_out         := v_msg;
      RETURN v_amount;
   EXCEPTION
      WHEN OTHERS
      THEN
         RETURN 0;
   END;
   -------------------------------
   FUNCTION early_ded_amt (p_bg_id           IN     NUMBER
                          ,p_assignment_id   IN     NUMBER
                          ,p_period_id       IN     NUMBER
                          ,p_start_date      IN     DATE
                          ,p_end_date        IN     DATE
						  ,p_religion        IN     VARCHAR2 -- Added for SR 226703
                          ,p_msg_out            OUT VARCHAR2)
      RETURN NUMBER
   AS
      e_val_err                EXCEPTION;
      e_val_param_err          EXCEPTION;
      v_err_msg                VARCHAR2 (1000);
      v_shift_name             VARCHAR2 (100);
      v_end_date               DATE;
      v_start_date             DATE;
      v_date                   DATE;
      v_count                  NUMBER;
      v_hours                  NUMBER;
      v_eff_date               DATE;
      v_out_eff_start_dt       DATE;
      v_out_eff_end_dt         DATE;
      v_out_elem_entry_id      NUMBER;
      v_out_ovn                NUMBER;
      v_out_create_warn        BOOLEAN;
      v_elem_name              pay_element_types_f.element_name%TYPE;
      v_elem_type_id           NUMBER;
      v_elem_link_id           NUMBER;
      v_inp_val_id             NUMBER;
      v_dual_shift_all         NUMBER;
      v_mult_shift_all         NUMBER;
      v_allowance_amount       NUMBER;
      v_elig_min_days          NUMBER;
      v_sh_start_time          NUMBER;
      v_sh_stop_time           NUMBER;
      v_sh_start_time_st       VARCHAR2 (10);
      v_sh_stop_time_st        VARCHAR2 (10);
      v_act_start_time         NUMBER;
      v_act_stop_time          NUMBER;
      v_holiday_cnt            NUMBER;
      v_amount                 NUMBER := 0;
      v_basic_sal              NUMBER;
      v_ded_perc               NUMBER;
      v_occurence              NUMBER;
      v_person_id              NUMBER;
      v_start_time_diff        NUMBER;
      v_stop_time_diff         NUMBER;
      v_days                   NUMBER;
      v_act_start_time_st      VARCHAR2 (10);
      v_act_stop_time_st       VARCHAR2 (10);
      v_msg                    VARCHAR2 (500);
      v_grace_time             NUMBER;
      v_grace_attempt          NUMBER;
      ---
      v_sh_start_time_st_dt    DATE;
      v_sh_stop_time_st_dt     DATE;
      v_act_start_time_st_dt   DATE;
      v_act_stop_time_st_dt    DATE;
      v_1_min_basic_sal        NUMBER;
      v_total_shift_hours      NUMBER;
      v_total_actual_hours     NUMBER;
      v_deduction_flag         VARCHAR2 (1);
      l_flag                   VARCHAR2 (1);
      v_record_exist           NUMBER;
      v_insert                 VARCHAR2 (1);
      v_employee_number        VARCHAR2 (140);
      v_occurence_rep          NUMBER;
   ---
      lc_admin_plan_yn          varchar2(1);        --Added for SR-211619
      lc_early_deduction_yn     varchar2(1);        --Added for SR-211619
      lc_early_deduction_mins   number;             --Added for SR-211619
      lc_calculation_type       varchar2(30);       --Added for SR-211619
	  c_chk_shift				NUMBER;			    --Added for SR-398109
   BEGIN
      v_date            := p_start_date;
      v_count           := 0;
      v_occurence       := 1;
      v_occurence_rep   := 0;
      v_basic_sal       := 0;
      v_msg             := ' ';
      LOOP
         EXIT WHEN v_date > p_end_date;
         v_amount   := 0;
         --Added for SR-211619 Starts
         lc_admin_plan_yn := xxoa_hr_late_early_ded_rep_new.is_admin_rotation_plan_yn(p_assignment_id,v_date,p_religion);  -- Added for SR 226703
         if lc_admin_plan_yn = 'Y' then
            lc_calculation_type := 'FLEXI';
         elsif lc_admin_plan_yn = 'N' then
            lc_calculation_type := 'GRACE';
         end if;
         /*=================*/
         /*Derive Person Id */
         /*=================*/
         BEGIN
            SELECT papf.person_id
                  ,papf.employee_number
            INTO   v_person_id
                  ,v_employee_number
            FROM   per_all_people_f papf
                  ,per_all_assignments_f paaf
				   ,per_grades pg ,per_jobs pj --added job and grade details for SR 427279
            WHERE  1 = 1
            AND    papf.person_id = paaf.person_id
            AND    paaf.assignment_id = p_assignment_id
            AND    paaf.primary_flag = 'Y'
            AND    v_date BETWEEN papf.effective_start_date
                              AND papf.effective_end_date
            AND    v_date BETWEEN paaf.effective_start_date
                              AND paaf.effective_end_date
			and   paaf.job_id = pj.job_id
            and   paaf.grade_id = pg.grade_id
            AND    v_date between pg.date_from  and nvl(pg.date_to,to_date('31-Dec-4712'))
            AND    v_date between pj.date_from  and nvl(pj.date_to,to_date('31-Dec-4712'))
			/* Commented For SR 177751 :: Start
            AND    EXISTS
                      (SELECT 1
                       FROM   fnd_lookup_values_vl
                       WHERE  lookup_type = 'XXOA_RUN_LATE_EARLY_DEDUCT_ORG'
                       AND    enabled_flag = 'Y'
                       AND    meaning =
                                 (SELECT name
                                  FROM   hr_all_organization_units
                                  WHERE  TYPE = 'SE'
                                  AND    organization_id =
                                            paaf.organization_id))
			Commented For Sr 177751 :: End */
			-- Added for SR 177751 :: START
			AND   NOT  EXISTS
                      (SELECT 1
                       FROM   fnd_lookup_values_vl
                       WHERE  lookup_type = 'XXOA_EXCLUD_LATE_EARLY_SECTION'
                       AND    enabled_flag = 'Y'
                       AND    meaning =
                                 (SELECT name
                                  FROM   hr_all_organization_units
                                  WHERE  TYPE = 'SE'
                                  AND    organization_id =
                                            paaf.organization_id)
                    --   and lc_admin_plan_yn = 'N'                           --Added for SR-211619  Commented For 223979
                      )
			-- Added for SR 177751 :: END
            AND    NOT EXISTS
                          (SELECT 1
                           FROM   fnd_lookup_values_vl
                           WHERE  lookup_type =
                                     'XXOA_EXCLUDE_LATE_EARLY_DEDUCT'
                           AND    enabled_flag = 'Y'
                           AND    meaning = papf.employee_number
                       --    and lc_admin_plan_yn = 'N'               --Added for SR-211619  Commented For 223979
                           )
			 ----added for SR427279------
			AND    NOT EXISTS
                          (SELECT 1
                           FROM   fnd_lookup_values_vl
                           WHERE  lookup_type =
                                     'XXOA_EXCL_JOB_LATE_EARLY_DED'
                           AND    enabled_flag = 'Y'
                           AND    meaning = pj.name
						   AND v_date BETWEEN start_date_active
								AND NVL(end_date_active,'31-DEC-4712')
                           )
			AND    NOT EXISTS
                          (SELECT 1
                           FROM   fnd_lookup_values_vl
                           WHERE  lookup_type =
                                     'XXOA_EXCL_GRADE_LATE_EARLY_DED'
                           AND    enabled_flag = 'Y'
                           AND    meaning = pg.name
						   AND v_date BETWEEN start_date_active
								AND NVL(end_date_active,'31-DEC-4712')
                           );
							  ----END : added for SR427279------
         EXCEPTION
            WHEN NO_DATA_FOUND
            THEN
               v_person_id   := NULL;
            WHEN TOO_MANY_ROWS
            THEN
               v_person_id   := NULL;
            WHEN OTHERS
            THEN
               v_person_id   := NULL;
         END;
         dbms ('v_person_id : ' || v_person_id);
		 log ('v_person_id : ' || v_person_id); --Added for SR#441873
         IF v_person_id IS NOT NULL
         THEN
            /*====================================*/
            /*Derive Shift Name and Holiday Count */
            /*====================================*/
            v_shift_name       := xxoa_otl_get_shift_name_fns (v_person_id
                                                              ,v_date
                                                              ,'NAME');
            v_holiday_cnt      := xxoa_otl_check_holiday_fns (v_person_id
                                                             ,v_date);
            dbms ('v_shift_name : ' || v_shift_name);  
			log ('v_shift_name : ' || v_shift_name); --Added for SR#441873
            dbms ('v_holiday_cnt: ' || v_holiday_cnt);
			log ('v_shift_name : ' || v_shift_name);  --Added for SR#441873

					----added for SR 398109---
		Begin
        c_chk_shift:=0;
         SELECT count(1) into c_chk_shift
         FROM apps.fnd_lookup_values_vl flv
         WHERE flv.lookup_type = 'XXOA_OTL_LATE_EARLY_SHIFT_EXCL'
         AND flv.enabled_flag  ='Y'
         AND v_date BETWEEN flv.start_date_active
         AND NVL(flv.end_date_active,'31-DEC-4712')
         AND Upper(Meaning) = Upper(v_shift_name);
         Exception when others then
         c_chk_shift:=0;
        End;

		 log ('c_chk_shift: ' || c_chk_shift);
----End for SR 398109---
        --    IF UPPER (v_shift_name) NOT LIKE '%OFF%' AND v_holiday_cnt = 0  ---commeted for SR 398109
			IF c_chk_shift <> 1 AND v_holiday_cnt = 0  ---added for SR 398109
            THEN
               /*================================*/
               /*Derive Shift Start And End Time */
               /*================================*/
               v_sh_start_time_st_dt      := TO_DATE (
                                                TO_CHAR (v_date
                                                        ,'MM/DD/RRRR')
                                                || LPAD (
                                                      xxoa_otl_get_shift_name_fns (
                                                         v_person_id
                                                        ,v_date
                                                        ,'START_TIME')
                                                     ,'4'
                                                     ,'0')
                                               ,'MM/DD/RRRRHH24MI');
               v_sh_stop_time_st_dt       := TO_DATE (
                                                TO_CHAR (v_date
                                                        ,'MM/DD/RRRR')
                                                || LPAD (
                                                      xxoa_otl_get_shift_name_fns (
                                                         v_person_id
                                                        ,v_date
                                                        ,'STOP_TIME')
                                                     ,'4'
                                                     ,'0')
                                               ,'MM/DD/RRRRHH24MI');
               v_sh_start_time_st         := LPAD (
                                                xxoa_otl_get_shift_name_fns (
                                                   v_person_id
                                                  ,v_date
                                                  ,'START_TIME')
                                               ,'4'
                                               ,'0');
               v_sh_stop_time_st          := LPAD (
                                                xxoa_otl_get_shift_name_fns (
                                                   v_person_id
                                                  ,v_date
                                                  ,'STOP_TIME')
                                               ,'4'
                                               ,'0');
               /* Added logic by Transsys to get correct stop time */
               IF v_sh_start_time_st_dt > v_sh_stop_time_st_dt
               THEN
                  v_sh_stop_time_st_dt   := v_sh_stop_time_st_dt + 1;


               /*  TO_DATE (   TO_CHAR (v_date + 1, 'MM/DD/RRRR')
                          || LPAD (xxoa_otl_get_shift_name_fns (v_person_id,
                                                                v_date + 1,
                                                                'STOP_TIME'
                                                               ),
                                   '4',
                                   '0'
                                  ),
                          'MM/DD/RRRRHH24MI'
                         ); */
               END IF;

               /* Added logic by Transsys to get correct stop time */
               dbms ('v_sh_start_time_st_dt : ' || v_sh_start_time_st_dt);
               dbms ('v_sh_stop_time_st_dt : ' || v_sh_stop_time_st_dt);
               dbms ('v_sh_start_time_st : ' || v_sh_start_time_st);
               dbms ('v_sh_stop_time_st : ' || v_sh_stop_time_st);
			   log ('v_sh_start_time_st_dt : ' || v_sh_start_time_st_dt); --Added for SR#441873
               log ('v_sh_stop_time_st_dt : ' || v_sh_stop_time_st_dt); --Added for SR#441873
               log ('v_sh_start_time_st : ' || v_sh_start_time_st); --Added for SR#441873
               log ('v_sh_stop_time_st : ' || v_sh_stop_time_st); --Added for SR#441873
               /*=====================================*/
               /*Derive the Actual start and end Time */
               /*=====================================*/
               BEGIN
                  v_act_start_time_st   := '0';
                  v_act_stop_time_st    := '0';
                  SELECT LPAD (TO_CHAR (MIN (xxtc.start_time)
                                       ,'HH24MI')
                              ,'4'
                              ,'0')
                        ,LPAD (TO_CHAR (MAX (xxtc.stop_time)
                                       ,'HH24MI')
                              ,'4'
                              ,'0')
                        ,MIN (xxtc.start_time)
                        ,MAX (xxtc.stop_time)
                  INTO   v_act_start_time_st
                        ,v_act_stop_time_st
                        ,v_act_start_time_st_dt
                        ,v_act_stop_time_st_dt
                  FROM   xxoa_otl_time_card_detail_v xxtc
                  WHERE  1 = 1
                  AND    xxtc.resource_id = v_person_id
                  AND    TRUNC (xxtc.punch_date) = v_date
                  AND    xxtc.approval_status = 'APPROVED';
               EXCEPTION
                  WHEN OTHERS
                  THEN
                     v_act_start_time_st      := '0';
                     v_act_stop_time_st       := '0';
                     v_act_start_time_st_dt   := NULL;
                     v_act_stop_time_st_dt    := NULL;
               END;
               dbms ('v_act_start_time_st : ' || v_act_start_time_st);
               dbms ('v_act_stop_time_st : ' || v_act_stop_time_st);
               dbms ('v_act_start_time_st_dt : ' || v_act_start_time_st_dt);
               dbms ('v_act_stop_time_st_dt : ' || v_act_stop_time_st_dt);
			   log ('v_act_start_time_st : ' || v_act_start_time_st); --Added for SR#441873
               log ('v_act_stop_time_st : ' || v_act_stop_time_st); --Added for SR#441873
               log ('v_act_start_time_st_dt : ' || v_act_start_time_st_dt); --Added for SR#441873
               log ('v_act_stop_time_st_dt : ' || v_act_stop_time_st_dt); --Added for SR#441873
               /*===========================*/
               /*===========================*/
               /*Derive Total Working Hours */
               /*===========================*/
               v_total_shift_hours        := 24
                                             * (v_sh_stop_time_st_dt
                                                - v_sh_start_time_st_dt);
               v_total_actual_hours       := 24
                                             * (v_act_stop_time_st_dt
                                                - v_act_start_time_st_dt);
               dbms ('v_total_shift_hours : ' || v_total_shift_hours);
               dbms ('v_total_actual_hours : ' || v_total_actual_hours);
			   log ('v_total_shift_hours : ' || v_total_shift_hours); --Added for SR#441873
               log ('v_total_actual_hours : ' || v_total_actual_hours); --Added for SR#441873
               /*==============================*/
               /*Convert Shift Stop in minutes*/
               /*==============================*/
               IF v_sh_stop_time_st = '0'
               THEN
                  v_sh_stop_time   := 0;
               ELSE
                  v_sh_stop_time      := (SUBSTR (v_sh_stop_time_st
                                                 ,1
                                                 ,2)
                                          * 60)
                                         + SUBSTR (v_sh_stop_time_st
                                                  ,-2);
               END IF;
               dbms ('v_sh_stop_time : ' || v_sh_stop_time);
			   log ('v_sh_stop_time : ' || v_sh_stop_time); --Added for SR#441873
               /*===============================*/
               /*Convert Actual Stop in minutes*/
               /*===============================*/
               IF v_act_stop_time_st = '0'
               THEN
                  v_act_stop_time   := 0;
               ELSE
                  v_act_stop_time      := (SUBSTR (v_act_stop_time_st
                                                  ,1
                                                  ,2)
                                           * 60)
                                          + SUBSTR (v_act_stop_time_st
                                                   ,-2);
               END IF;
               dbms ('v_act_stop_time : ' || v_act_stop_time);
			   log ('v_act_stop_time : ' || v_act_stop_time); --Added for SR#441873
               /*==========================================================*/
               /*Calcualte the time difference between actual and scheduled*/
               /*==========================================================*/
               IF v_act_stop_time = 0
               THEN
                  v_stop_time_diff   := 9999;

                 ELSE
                  /* Added by transsys to get correct stop time difference*/
                  --v_stop_time_diff   := v_sh_stop_time - v_act_stop_time;
				  --
				  --Added by Deepak as start of code for shift stop time as per SR 297464
                  IF ((TRUNC(v_sh_stop_time_st_dt) != TRUNC(v_act_stop_time_st_dt)) AND (v_sh_stop_time < v_act_stop_time))  THEN
                    v_sh_stop_time := 1440 + v_sh_stop_time;
                  END IF;
					dbms ('v_sh_stop_time_222 : ' || v_sh_stop_time);
					log ('v_sh_stop_time_222 : ' || v_sh_stop_time); --Added for SR#441873
					--End of Code for shift stop time as per SR 297464
					--
                    v_stop_time_diff   := abs(v_act_stop_time - v_sh_stop_time);
                 END IF;
                 dbms ('v_stop_time_diff : ' || v_stop_time_diff);
				 log ('v_stop_time_diff : ' || v_stop_time_diff); --Added for SR#441873

                IF TRUNC(v_sh_stop_time_st_dt) = TRUNC(v_act_stop_time_st_dt)
                THEN

                   v_stop_time_diff   := abs(v_sh_stop_time - v_act_stop_time);
                     log ( 'v_stop_time_diff222 : ' || v_stop_time_diff); 
                 END IF;

               dbms ('v_stop_time_diff : ' || v_stop_time_diff);
               log ('v_stop_time_diff : ' || v_stop_time_diff); --Added for SR#441873

                 log ( 'v_act_stop_time : ' || v_act_stop_time);
                 log ( 'v_start_time_diff : ' || v_start_time_diff);
                 log ( 'v_act_stop_time_st : ' || v_act_stop_time_st);
                 log ( 'v_sh_stop_time_st : ' || v_sh_stop_time_st);
                 log ( 'v_act_start_time_st_dt : ' || v_act_start_time_st_dt);
                 log ( 'v_act_stop_time_st_dt : ' || v_act_stop_time_st_dt);
                 log ( 'v_total_shift_hours : ' || v_total_shift_hours);
                 log ( 'v_total_actual_hours : ' || v_act_stop_time_st_dt);
                 log ( 'v_stop_time_diff : ' || v_stop_time_diff);
                 log ( 'v_amount : ' || v_amount);
               /*=================================================*/
               /*Global Values for Grace Time and allowed Attempts*/
               /*=================================================*/
               BEGIN
                  SELECT global_value
                  INTO   v_grace_time
                  FROM   ff_globals_f
                  WHERE  global_name = 'XXOA_EARLY_GOING_GRACE_TIME'
                  AND    SYSDATE BETWEEN effective_start_date
                                     AND effective_end_date
                  AND    business_group_id =
                            fnd_profile.VALUE ('PER_BUSINESS_GROUP_ID');
               END;
               BEGIN
                  SELECT global_value
                  INTO   v_grace_attempt
                  FROM   ff_globals_f
                  WHERE  global_name = 'XXOA_EARLY_GO_GRACE_ATTEMPT'
                  AND    SYSDATE BETWEEN effective_start_date
                                     AND effective_end_date
                  AND    business_group_id =
                            fnd_profile.VALUE ('PER_BUSINESS_GROUP_ID');
               END;
               dbms ('v_grace_attempt : ' || v_grace_attempt);
			   log ('v_grace_attempt : ' || v_grace_attempt); --Added for SR#441873
               /*==========================*/
               /*Basic Salary For a Minut */
               /*=========================*/
               v_basic_sal                := xxoa_payroll_all.
                                              get_basic_salary (
                                                p_bg_id
                                               ,p_assignment_id
                                               ,v_date);
               v_days                     :=   TRUNC (LAST_DAY (p_end_date))
                                             - TRUNC (p_end_date
                                                     ,'MM')
                                             + 1;
               v_1_min_basic_sal          := (v_basic_sal * 12)
                                             / (60
                                                * (240 * v_total_shift_hours));
               dbms ('v_basic_sal : ' || v_basic_sal);
			   log  ('v_basic_sal : ' || v_basic_sal); ----Added for SR#441873
               dbms ('v_days : ' || v_days);
			   log ('v_days : ' || v_days);
               dbms ('v_1_min_basic_sal : ' || v_1_min_basic_sal);
			   log ('v_1_min_basic_sal : ' || v_1_min_basic_sal);
               /*===============================*/
               /*Derive Conditions as per policy*/
               /*===============================*/
            /* Commented by Venkat to fix the early going grace issue on 20/12/2015*/
              IF (
                  (v_act_stop_time_st_dt < v_sh_stop_time_st_dt and lc_admin_plan_yn = 'N')        --Added for SR-211619
                  or                                                                               --Added for SR-211619
                  (lc_admin_plan_yn = 'Y')                                                         --Added for SR-211619
                 )
               THEN
--                  v_occurence_rep   := v_occurence_rep + 1;                   --Commented for SR-211619
--                  dbms ('v_occurence_rep : ' || v_occurence_rep);             --Commented for SR-211619
--                  LOG ('v_occurence_rep : ' || v_occurence_rep);              --Commented for SR-211619

    --Added for SR-211619 Starts
                    lc_early_deduction_yn := xxoa_hr_late_early_ded_rep_new.get_flexi_late_early_dtls(p_assignment_id,v_date
                                                                                                    ,v_sh_start_time_st_dt,v_sh_stop_time_st_dt
                                                                                                    ,v_act_start_time_st_dt,v_act_stop_time_st_dt
                                                                                                    ,'EARLY_DEDUCTION_YN'
                                                                                                    );
                    v_deduction_flag := lc_early_deduction_yn;

                 if lc_admin_plan_yn = 'Y' then

                    if v_deduction_flag = 'Y' then
                        v_occurence_rep := v_occurence_rep + 1;
                        dbms ('v_occurence_rep : ' || v_occurence_rep);
						log ('v_occurence_rep : ' || v_occurence_rep);
                    end if;

                 elsif lc_admin_plan_yn = 'N' then
                        v_occurence_rep := v_occurence_rep + 1;
                        dbms ('v_occurence_rep : ' || v_occurence_rep);
						log ('v_occurence_rep : ' || v_occurence_rep);
    --Added for SR-211619 Ends

                        IF v_stop_time_diff <= v_grace_time
                        THEN
                           IF v_occurence > v_grace_attempt
                           THEN
                              v_deduction_flag   := 'Y';
                           ELSE
                              v_deduction_flag   := 'N';
                              dbms ('v_occurence : ' || v_occurence);
                              LOG ('v_occurence : ' || v_occurence);
                              v_occurence        := v_occurence + 1;
                           END IF;
                        ELSE
                           v_deduction_flag   := 'Y';
                        END IF;
                        dbms ('v_deduction_flag : ' || v_deduction_flag);
                        LOG ('v_deduction_flag : ' || v_deduction_flag);
                 end if;                      --Added for SR-211619
              /* Commented by Venkat to fix the early going grace issue on 20/12/2015*/
                 /* Added by Venkat to fix the early going grace issue on 20/12/2015*/
                IF (
                    (v_act_stop_time_st_dt < v_sh_stop_time_st_dt and lc_admin_plan_yn = 'N')        --Added for SR-211619
                    or                                                                               --Added for SR-211619
                    (lc_admin_plan_yn = 'Y')                                                         --Added for SR-211619
                   )
                THEN
