  FUNCTION get_prev_rotation_plan(
                             p_assignment_id  number
                            ,p_effective_date date
                              )
  RETURN VARCHAR2
  IS
    cursor cur_rot_plan
    is
     SELECT PREV_RP FROM(
     SELECT *  FROM (select paa.assignment_id
       ,hrp.name rp
       ,LAG(hrp.name) OVER (PARTITION BY paa.assignment_id ORDER BY haif.effective_start_date ) AS prev_rp
       ,haif.effective_start_date rotation_plan_eff_dt
       from  per_all_people_f      pap
            ,per_all_assignments_f paa
            ,hxt_add_assign_info_f haif
            ,hxt_rotation_plans    hrp
      where pap.person_id      = paa.person_id
        and paa.assignment_id  = haif.assignment_id
        and haif.rotation_plan = hrp.id
        and (p_effective_date) between pap.effective_start_date  and pap.effective_end_date
        and (p_effective_date) between paa.effective_start_date  and paa.effective_end_date
        and paa.assignment_id = p_assignment_id )s WHERE s.rp != prev_rp and s.rotation_plan_eff_dt <= p_effective_date order by s.rotation_plan_eff_dt desc) WHERE ROWNUM=1
        ;

     rec_rot_plan cur_rot_plan%rowtype;
  BEGIN

     open  cur_rot_plan;
     fetch cur_rot_plan into rec_rot_plan;
     close cur_rot_plan;

     return (rec_rot_plan.PREV_RP);

  exception
     when others then return null;
  END;
