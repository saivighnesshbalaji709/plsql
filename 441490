  PROCEDURE XXOA_LINK_EMP2USER_ALL(p_errbuf    OUT   VARCHAR2,
   p_retcode   OUT   NUMBER) IS
l_cnt number :=0;
/******************************************************************************
   NAME:       XXOA_LINK_EMP2USER_ALL
   PURPOSE: Linking the FND_USER with Employee and assign the Default  Responsibility    

   REVISIONS:
   Ver        Date        Author           Description
   ---------  ----------  ---------------  ------------------------------------
   1.0        8/25/2013   6801       1. Created this procedure.

******************************************************************************/
begin

for c in (
select employee_number   from apps.per_all_people_f
where employee_number in (select user_name from apps.fnd_user u where EMPLOYEE_ID   is null
and END_DATE is null
and ascii(substr(user_name,1,1)) between 49 and 57
and user_name not like'%DS' and  user_name not like '%OLD')  
and EFFECTIVE_END_DATE > sysdate
and CURRENT_EMPLOYEE_FLAG='Y')

Loop
    dbms_output.put_line(c.employee_number);
     XXOA_LINK_EMP2USER(c.employee_number);
 
End Loop;
l_cnt:=0;
begin

SELECT  count(1) into l_cnt 
FROM   XXOA_RESP_ERR_TABLE  WHERE   upper(STATUS) = 'FAIL';

 if    l_cnt<>0
 then
XXOA_RESP_ERROR_MAIL;
end if;
exception when others then
    dbms_output.put_line('Error in Mail sending  : ' ||(SUBSTR (SQLERRM, 1, 254)));
end;

END XXOA_LINK_EMP2USER_ALL;

