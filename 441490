PROCEDURE      xxoa_link_emp2user (p_employee_id VARCHAR2)
IS
   l_person_id               NUMBER;
   l_user_id                 NUMBER;
   l_party_id                NUMBER;
   l_email_address           VARCHAR2 (100);
   l_return_status           VARCHAR2 (1);
   l_msg_count               NUMBER;
   l_msg_data                VARCHAR2 (240);
   exception_tag_user_id     NUMBER;
   api_unexpectedly_failed   EXCEPTION;
   l_emp_exists              BOOLEAN;
   l_assignemnt_exists       BOOLEAN;
   l_user_exists             BOOLEAN;
   l_resp_count              NUMBER;
   l_sec_attrib_count        NUMBER;
   l_emp_num                 VARCHAR2(10);
   l_payroll                 VARCHAR2(40):=null;
   l_resp_key                VARCHAR2(180):=null;
   l_appl_name              VARCHAR2(40):=null;
   l_emp_name            varchar2(400):=null;
   
cursor c_resp_Det (p_payroll Varchar2)   is 
SELECT pur.row_low_range_or_name resp_name, pucif.value resp_key
FROM pay_user_column_instances_f pucif
,pay_user_rows_f pur
,pay_user_columns puc
,pay_user_tables put
WHERE put.user_table_id = puc.user_table_id
AND put.user_table_id = pur.user_table_id
AND pucif.user_row_id = pur.user_row_id
AND pucif.user_column_id = puc.user_column_id
AND trunc(SYSDATE) BETWEEN pur.effective_start_date
AND pur.effective_end_date
AND trunc(SYSDATE) BETWEEN pucif.effective_start_date
AND pucif.effective_end_date
AND upper(puc.user_column_name) = upper(p_payroll)
AND put.user_table_name = 'XXOA_PAYROLLWISE_RESPONSIBILITY';
   
BEGIN
   BEGIN
      l_emp_exists := TRUE;
 
      SELECT person_id, party_id,full_name
        INTO l_person_id, l_party_id,l_emp_name
        FROM per_all_people_f
       WHERE     employee_number = p_employee_id
             AND SYSDATE BETWEEN effective_start_date AND effective_end_date
             and current_employee_flag='Y';
   EXCEPTION
      WHEN OTHERS
      THEN
         l_emp_exists := FALSE;
         XXOA_INSERT_ERR_MSG(p_employee_id,l_emp_name,'Employee record not created yet or it is not active.',sysdate,'Fail');
          fnd_file.put_line (fnd_file.LOG,p_employee_id ||'  Employee record not created yet or it is not active ' );
   END;
---- XXOA_INSERT_ERR_MSG(p_employee_id,l_emp_name,'Payroll Name for Emp is not available . ',sysdate,'Fail');
   BEGIN
      l_assignemnt_exists := TRUE;

      SELECT person_id, assignment_number,(select payroll_name from pay_payrolls_f where PAYROLL_ID =paaf.payroll_id) payroll_name
   INTO l_person_id, l_emp_num,l_payroll
        FROM per_all_assignments_f paaf
       WHERE     person_id = l_person_id and assignment_type='E'
             AND SYSDATE BETWEEN effective_start_date AND effective_end_date;
   EXCEPTION
      WHEN OTHERS
      THEN
         l_assignemnt_exists := FALSE;
        XXOA_INSERT_ERR_MSG(p_employee_id,l_emp_name,'Employee assignment not created yet or it is not active.',sysdate,'Fail');
          fnd_file.put_line (fnd_file.LOG,p_employee_id ||'   Employee assignment not created yet or it is not active.');
   END;
   if l_emp_num <> p_employee_id then
       l_assignemnt_exists := FALSE;
          XXOA_INSERT_ERR_MSG(p_employee_id,l_emp_name,'Employee assignment number doest not match the employee number.',sysdate,'Fail');
         fnd_file.put_line (fnd_file.LOG,p_employee_id||'  Employee assignment number doest not match the employee number.');
       
   end if;

   BEGIN
      l_user_exists := TRUE;

      SELECT user_id, email_address
        INTO l_user_id, l_email_address
        FROM fnd_user u
       WHERE u.user_name = p_employee_id;
   EXCEPTION
      WHEN OTHERS
      THEN
         l_user_exists := FALSE;
          XXOA_INSERT_ERR_MSG(p_employee_id,l_emp_name,'User Account not created yet.',sysdate,'Fail');
          fnd_file.put_line (fnd_file.LOG,p_employee_id||'  User Account not created yet,');
   END;
If l_payroll is not null then
   IF l_user_exists AND l_emp_exists AND l_assignemnt_exists
   THEN
   
      fnd_user_pkg.updateuserPARTY (x_user_name         => p_employee_id,
                                    X_OWNER             => 'CUSTOM',
                                    X_PERSON_PARTY_ID   => l_party_id);
      fnd_user_pkg.updateuser (x_user_name       => p_employee_id,
                               X_OWNER           => 'CUSTOM',
                               X_employee_ID     => l_person_id,
                               X_customer_id     => FND_USER_PKG.NULL_NUMBER,
                               X_email_address   => l_email_address);

      COMMIT;
/*l_resp_key:=null;
If l_payroll is not null then
If upper(l_payroll)=upper('Base Payroll')
then l_resp_key := 'OAHR_HQ_EMPLOYEE_DIRECT_ACCESS';
elsif  upper(l_payroll)=upper('Cargo Payroll')
then 
l_resp_key := 'OAHR_CARGO_EMP_DIRECT_ACCESS';
elsif upper(l_payroll)=upper('Catering Payroll')
then 
l_resp_key := 'OAHR_CATER_EMP_DIRECT_ACCESS';
elsif  upper(l_payroll)=upper('OGH Payroll')
then
l_resp_key := 'OAHR_OGH_EMP_DIRECT_ACCESS';
else
l_resp_key := 'OAHR_IND_EMPLOYEE_DIRECT_ACCES';
end if;
else
l_resp_key:=null;
  XXOA_INSERT_ERR_MSG(p_employee_id,'Payroll Name for Emp is not available . ',sysdate,'Fail');
 end if;
*/


if l_payroll not in ('Base Payroll','Cargo Payroll','Catering Payroll','OGH Payroll','Unclassified Payroll','Executive Payroll') --Added Unclassified and Executive Payroll for SR#441490
then l_payroll := 'Outstation Payroll';
end if;
FOR rec_resp in c_resp_det(l_payroll)
LOOP
 
      SELECT COUNT (1)
        INTO l_resp_count
        FROM fnd_user_resp_groups furg, fnd_user fu, fnd_responsibility fr
       WHERE     furg.user_id = fu.user_id
             AND furg.responsibility_id = fr.responsibility_id
             AND fu.user_name = p_employee_id
             AND fr.responsibility_key = rec_resp.resp_key---'OAHR_HQ_EMPLOYEE_DIRECT_ACCESS'
             AND SYSDATE BETWEEN fu.start_date
                             AND NVL (fu.end_date, '31-dec-2412');

      begin
       l_appl_name:=null;
       select APPLICATION_SHORT_NAME into l_appl_name
    from fnd_application fa ,fnd_responsibility fr 
    where fa.APPLICATION_ID=fr.APPLICATION_ID
        and fr.RESPONSIBILITY_KEY=rec_resp.resp_key;
     exception when others then
XXOA_INSERT_ERR_MSG(p_employee_id,l_emp_name,
 'Error in fetching application sort name for  '||rec_resp.resp_name||' '||(SUBSTR (SQLERRM, 1, 254)),sysdate,'Fail');
  end ;
 

      IF l_resp_count = 0 and l_appl_name is not null
      THEN
       begin

       fnd_user_pkg.addresp (username         => p_employee_id,
                               resp_app         => l_appl_name,---'PER',
                               resp_key         => rec_resp.resp_key,----'OAHR_HQ_EMPLOYEE_DIRECT_ACCESS',
                               security_group   => 'STANDARD',
                               description      => NULL,
                               start_date       => SYSDATE,
                               end_date         => NULL);
                               exception when others then
                               XXOA_INSERT_ERR_MSG(p_employee_id,l_emp_name,
                            'Error in '||rec_resp.resp_name||'  
                            Responsibility addition API  . '||(SUBSTR (SQLERRM, 1, 254)),sysdate,'Fail');
                         
                         end ;
         COMMIT;
          fnd_file.put_line (fnd_file.LOG,rec_resp.resp_name||' added for Emp number  '||p_employee_id);
      ELSE
          fnd_file.put_line (fnd_file.LOG,rec_resp.resp_name||' already active for Emp Number  '||p_employee_id);
      END IF;

End loop;

      SELECT COUNT (1)
        INTO l_sec_attrib_count
        FROM AK_WEB_USER_SEC_ATTR_VALUES
       WHERE     web_user_id = l_user_id
             AND attribute_code = 'ICX_HR_PERSON_ID'
             AND attribute_application_id = 178;

      IF l_sec_attrib_count = 0
      THEN
     
     Begin
     icx_user_sec_attr_pub.create_user_sec_attr (
            p_api_version_number   => 1,
            p_web_user_id          => l_user_id,
            p_attribute_code       => 'ICX_HR_PERSON_ID',
            p_attribute_appl_id    => 178,
            p_varchar2_value       => fnd_api.g_false,
            p_date_value           => fnd_api.g_miss_date,
            p_number_value         => l_person_id,
            p_created_by           => '-1',
            p_creation_date        => SYSDATE,
            p_last_updated_by      => '-1',
            p_last_update_date     => SYSDATE,
            p_last_update_login    => '-1',
            p_return_status        => l_return_status,
            p_msg_count            => l_msg_count,
            p_msg_data             => l_msg_data);
          fnd_file.put_line (fnd_file.LOG,'Security Attribute ICX_HR_PERSON_ID added for Emp Number  '||p_employee_id);
         exception when others then
        XXOA_INSERT_ERR_MSG(p_employee_id,l_emp_name,'Error in Security Attribute ICX_HR_PERSON_ID  addition API  . '||(SUBSTR (SQLERRM, 1, 254)),sysdate,'Fail');
        End;
      ELSE
          fnd_file.put_line (fnd_file.LOG,'Security Attribute ICX_HR_PERSON_ID already set for Emp Number  '||p_employee_id);
      END IF;

      SELECT COUNT (1)
        INTO l_sec_attrib_count
        FROM AK_WEB_USER_SEC_ATTR_VALUES
       WHERE     web_user_id = l_user_id
             AND attribute_code = 'TO_PERSON_ID'
             AND attribute_application_id = 178;

      IF l_sec_attrib_count = 0
      THEN
      BEGIN
         icx_user_sec_attr_pub.create_user_sec_attr (
            p_api_version_number   => 1,
            p_web_user_id          => l_user_id,
            p_attribute_code       => 'TO_PERSON_ID',
            p_attribute_appl_id    => 178,
            p_varchar2_value       => fnd_api.g_false,
            p_date_value           => fnd_api.g_miss_date,
            p_number_value         => l_person_id,
            p_created_by           => '-1',
            p_creation_date        => SYSDATE,
            p_last_updated_by      => '-1',
            p_last_update_date     => SYSDATE,
            p_last_update_login    => '-1',
            p_return_status        => l_return_status,
            p_msg_count            => l_msg_count,
            p_msg_data             => l_msg_data);
          fnd_file.put_line (fnd_file.LOG,'Security Attribute TO_PERSON_ID added for Emp Number  '||p_employee_id);
         exception when others then
        XXOA_INSERT_ERR_MSG(p_employee_id,l_emp_name,'Error in Security Attribute to person  addition API  . '||(SUBSTR (SQLERRM, 1, 254)),sysdate,'Fail');
        End;
      ELSE
          fnd_file.put_line (fnd_file.LOG,'Security Attribute TO_PERSON_ID already set  for Emp Number  '||p_employee_id);
      END IF;
     begin
      fnd_user_pkg.user_synch (p_employee_id);
       exception when others then
        XXOA_INSERT_ERR_MSG(p_employee_id,l_emp_name,'Error in fnd_user_pkg user_synch API call . '||(SUBSTR (SQLERRM, 1, 254)),sysdate,'Fail');
        End;
      COMMIT;
       fnd_file.put_line (fnd_file.LOG,'Employee Id attached to User record for Emp Number  '||p_employee_id);
   END IF;
   else

  XXOA_INSERT_ERR_MSG(p_employee_id,l_emp_name,'Payroll Name for Emp is not available . ',sysdate,'Fail');
 end if;
END;
end XXOA_LINK_EMP2USER_ALL_PKG;  
