FUNCTION xxoa_snydate_exp_fnc (p_asg_id          IN NUMBER,
							   p_start_date      IN   DATE,
                               p_end_date        IN   DATE)
   RETURN VARCHAR2
IS
   v_exp_flag   VARCHAR2(10):='Y';
   v_start_date DATE:=p_start_date;
   v_end_date DATE:=p_end_date;

BEGIN

LOOP
BEGIN
select 'Y'
INTO v_exp_flag
from apps.per_analysis_criteria pac1,
apps.per_person_analyses ppa1,
apps.fnd_id_flex_structures_vl ffs1,
apps.per_all_people_f papf,
apps.per_all_assignments_f paaf
where ppa1.person_id = papf.person_id
and papf.person_id=paaf.person_id
and ffs1.id_flex_num = ppa1.id_flex_num
and ffs1.id_flex_code = 'PEA'
and ffs1.id_flex_structure_name = 'Annual Leave SNY/LC Exception'
and pac1.id_flex_num = ppa1.id_flex_num
and pac1.analysis_criteria_id = ppa1.analysis_criteria_id
and paaf.primary_flag = 'Y'
and papf.current_employee_flag = 'Y'
and paaf.assignment_id=p_asg_id
and sysdate between papf.effective_start_date and papf.effective_end_date
and sysdate between paaf.effective_start_date and paaf.effective_end_date
and to_date(v_start_date,'DD-MM-YYYY') between to_date(to_char(fnd_date.canonical_to_date (pac1.segment1)),'DD-MM-YYYY') and to_date(to_char(fnd_date.canonical_to_date (pac1.segment2)),'DD-MM-YYYY')
order by employee_number
;
dbms_output.put_line('v_exp_flag: '||v_exp_flag);
EXCEPTION
WHEN NO_DATA_FOUND THEN
v_exp_flag :='N';
dbms_output.put_line('v_exp_flag: '||v_exp_flag);
END;
EXIT WHEN (v_start_date=v_end_date)or v_exp_flag='N';
v_start_date:=v_start_date+1;
END LOOP;
RETURN v_exp_flag;
END xxoa_snydate_exp_fnc;

