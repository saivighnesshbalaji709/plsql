--------------------------------------------------------------
--Function to get No of Leaves Taken by passing Assignment_id
-------------------------------------------------------------
   FUNCTION get_no_of_leaves_taken_ass_id (
      p_business_group_id   IN   NUMBER,
      p_assignment_id       IN   NUMBER,
      p_absence_type        IN   VARCHAR2,
      p_period_start_date   IN   DATE,
      p_period_end_date     IN   DATE
   )
      RETURN NUMBER
   IS
      -- Cursor to get the absence dates for an assignment id
      CURSOR cur_rec_absence_dates
      IS
         SELECT DISTINCT paa.date_start, paa.date_end
                    FROM per_absence_attendances paa,
                         per_absence_attendance_types paat
                   WHERE paa.absence_attendance_type_id =
                                               paat.absence_attendance_type_id
                     AND person_id =
                            (SELECT person_id
                               FROM per_all_assignments_f
                              WHERE assignment_id = p_assignment_id
                                AND primary_flag = 'Y'
                                AND business_group_id = p_business_group_id
                                AND p_period_end_date
                                       BETWEEN effective_start_date
                                           AND effective_end_date)
                     AND TRIM (UPPER (paat.NAME)) =
                                                 TRIM (UPPER (p_absence_type))
                ORDER BY 1;

      --Declaring the variables
      v_person_id            NUMBER         := 0;
      v_cnt                  NUMBER         := 0;
      v_no_of_leaves_taken   NUMBER         := 0;
      v_no_of_leaves         NUMBER         := 0;
      v_days_cnt             NUMBER         := 0;
      v_holiday              NUMBER         := 0;
      v_flying_staff         VARCHAR2 (100)
         := xxoa_payroll_all.get_flying_staff (p_business_group_id,
                                               p_assignment_id,
                                               p_period_end_date
                                              );
   -- Begin Block
   BEGIN
      --Fetch the person_id for the respective employee
      BEGIN
         SELECT person_id
           INTO v_person_id
           FROM per_all_assignments_f
          WHERE assignment_id = p_assignment_id
            AND business_group_id = p_business_group_id
            AND p_period_end_date BETWEEN effective_start_date
                                      AND effective_end_date;
      EXCEPTION
         WHEN NO_DATA_FOUND
         THEN
            v_person_id := -1;
         WHEN TOO_MANY_ROWS
         THEN
            v_person_id := 0;
         WHEN OTHERS
         THEN
            v_person_id := 0;
      END;

      --Passing the leave dates in Loop
      FOR v_cur_rec IN cur_rec_absence_dates
      LOOP
         v_holiday := 0;

         -- Checking the condition Leave date falling between start date and end end date in same month
         IF (    v_cur_rec.date_start BETWEEN p_period_start_date
                                          AND p_period_end_date
             AND v_cur_rec.date_end BETWEEN p_period_start_date
                                        AND p_period_end_date
            )
         THEN
            BEGIN
               SELECT ABS (v_cur_rec.date_end - v_cur_rec.date_start) + 1
                 INTO v_cnt
                 FROM per_absence_attendances paa1,
                      per_absence_attendance_types paat1
                WHERE paa1.absence_attendance_type_id =
                                              paat1.absence_attendance_type_id
                  AND person_id = v_person_id
                  AND UPPER (paat1.NAME) = UPPER (p_absence_type)
                  AND paa1.date_start BETWEEN v_cur_rec.date_start
                                          AND v_cur_rec.date_end
                  AND paa1.date_end BETWEEN v_cur_rec.date_start
                                        AND v_cur_rec.date_end
                  AND ROWNUM = 1;
            EXCEPTION
               WHEN NO_DATA_FOUND
               THEN
                  v_cnt := -1;
               WHEN TOO_MANY_ROWS
               THEN
                  v_cnt := 0;
               WHEN OTHERS
               THEN
                  v_cnt := 0;
            END;

            --getting the number of holidays between two dates
            IF     NVL (v_flying_staff, 'XX') <> 'FLY'
               AND (   UPPER (p_absence_type) = UPPER ('Annual Leave')
                    OR UPPER (p_absence_type) = UPPER ('Leave Bank')
                   )
            THEN
               v_holiday :=
                  NVL (holidays (p_assignment_id,
                                 v_cur_rec.date_start,
                                 v_cur_rec.date_end
                                ),
                       0
                      );
            ELSE
               v_holiday := 0;
            END IF;

            --getting the number of leaves an employee availaed after deducting holidays
            v_no_of_leaves := v_no_of_leaves + v_cnt - v_holiday;
         ELSIF (    v_cur_rec.date_start BETWEEN p_period_start_date
                                             AND p_period_end_date
                AND v_cur_rec.date_end NOT BETWEEN p_period_start_date
                                               AND p_period_end_date
               )
         THEN
            BEGIN
               SELECT ABS (v_cur_rec.date_start - p_period_end_date) + 1
                 INTO v_cnt
                 FROM per_absence_attendances paa2,
                      per_absence_attendance_types paat2
                WHERE paa2.absence_attendance_type_id =
                                              paat2.absence_attendance_type_id
                  AND person_id = v_person_id
                  AND UPPER (paat2.NAME) = UPPER (p_absence_type)
                  AND paa2.date_start BETWEEN v_cur_rec.date_start
                                          AND p_period_end_date
                  AND ROWNUM = 1;
            EXCEPTION
               WHEN NO_DATA_FOUND
               THEN
                  v_cnt := -1;
               WHEN TOO_MANY_ROWS
               THEN
                  v_cnt := 0;
               WHEN OTHERS
               THEN
                  v_cnt := 0;
            END;

            --getting the number of holidays between two dates
            IF     NVL (v_flying_staff, 'XX') <> 'FLY'
               AND (   UPPER (p_absence_type) = UPPER ('Annual Leave')
                    OR UPPER (p_absence_type) = UPPER ('Leave Bank')
                   )
            THEN
               v_holiday :=
                  NVL (holidays (p_assignment_id,
                                 v_cur_rec.date_start,
                                 p_period_end_date
                                ),
                       0
                      );
            ELSE
               v_holiday := 0;
            END IF;

            --getting the number of leaves an employee availaed after deducting holidays
            v_no_of_leaves := v_no_of_leaves + v_cnt - v_holiday;
         ELSIF (    v_cur_rec.date_start NOT BETWEEN p_period_start_date
                                                 AND p_period_end_date
                AND v_cur_rec.date_end BETWEEN p_period_start_date
                                           AND p_period_end_date
               )
         THEN
            BEGIN
               SELECT ABS (v_cur_rec.date_end - p_period_start_date) + 1
                 INTO v_cnt
                 FROM per_absence_attendances paa3,
                      per_absence_attendance_types paat3
                WHERE paa3.absence_attendance_type_id =
                                              paat3.absence_attendance_type_id
                  AND person_id = v_person_id
                  AND UPPER (paat3.NAME) = UPPER (p_absence_type)
                  AND paa3.date_end BETWEEN p_period_start_date
                                        AND p_period_end_date
                  AND ROWNUM = 1;
            EXCEPTION
               WHEN NO_DATA_FOUND
               THEN
                  v_cnt := -1;
               WHEN TOO_MANY_ROWS
               THEN
                  v_cnt := 0;
               WHEN OTHERS
               THEN
                  v_cnt := 0;
            END;

            --getting the number of holidays between two dates
            IF     NVL (v_flying_staff, 'XX') <> 'FLY'
               AND (   UPPER (p_absence_type) = UPPER ('Annual Leave')
                    OR UPPER (p_absence_type) = UPPER ('Leave Bank')
                   )
            THEN
               v_holiday :=
                  NVL (holidays (p_assignment_id,
                                 p_period_start_date,
                                 v_cur_rec.date_end
                                ),
                       0
                      );
            ELSE
               v_holiday := 0;
            END IF;

            --getting the number of leaves an employee availed after deducting holidays
            v_no_of_leaves := v_no_of_leaves + v_cnt - v_holiday;
         ELSIF (    v_cur_rec.date_start < p_period_start_date
                AND v_cur_rec.date_end > p_period_end_date
               )
         THEN
            BEGIN
               SELECT ABS (p_period_start_date - p_period_end_date) + 1
                 INTO v_days_cnt
                 FROM per_absence_attendances paa4,
                      per_absence_attendance_types paat4
                WHERE paa4.absence_attendance_type_id =
                                              paat4.absence_attendance_type_id
                  AND person_id = v_person_id
                  AND UPPER (paat4.NAME) = UPPER (p_absence_type)
                  AND paa4.date_start = v_cur_rec.date_start
                  AND ROWNUM = 1;
            EXCEPTION
               WHEN NO_DATA_FOUND
               THEN
                  v_cnt := -1;
               WHEN TOO_MANY_ROWS
               THEN
                  v_cnt := 0;
               WHEN OTHERS
               THEN
                  v_cnt := 0;
            END;

            --getting the number of holidays between two dates
            IF     NVL (v_flying_staff, 'XX') <> 'FLY'
               AND (   UPPER (p_absence_type) = UPPER ('Annual Leave')
                    OR UPPER (p_absence_type) = UPPER ('Leave Bank')
                   )
            THEN
               v_holiday :=
                  NVL (holidays (p_assignment_id,
                                 p_period_start_date,
                                 p_period_end_date
                                ),
                       0
                      );
            ELSE
               v_holiday := 0;
            END IF;

            v_cnt := v_days_cnt;
            v_no_of_leaves := v_no_of_leaves + v_cnt - v_holiday;
         END IF;
      END LOOP;

      v_no_of_leaves_taken := v_no_of_leaves;
      RETURN v_no_of_leaves_taken;
   EXCEPTION
      WHEN NO_DATA_FOUND
      THEN
         RETURN -1;
      WHEN TOO_MANY_ROWS
      THEN
         RETURN 0;
      WHEN OTHERS
      THEN
         RETURN 0;
   END get_no_of_leaves_taken_ass_id;



