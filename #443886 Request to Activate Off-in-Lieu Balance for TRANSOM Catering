--Function to check if a given day is a holiday or not
--------------------------------------------------------
   FUNCTION holidays (
      p_assignment_id   IN   NUMBER,
      p_start_date      IN   DATE,
      p_end_date        IN   DATE
   )
      RETURN NUMBER
   IS
      --Local Variable declaration
      v_hcl_id          NUMBER;
      v_no_of_nh        NUMBER        := 0;
      --      v_person_id   NUMBER;
      v_policy_exists   VARCHAR2 (10);
      v_calendar_name   VARCHAR2 (100);---added for SR 354732
      v_prl_name         VARCHAR2 (100);---added for SR 354732
      v_region_name      VARCHAR2 (100);---added for SR 431846

      --Cursor to get the earning policy for an employee
      CURSOR cur_earn_pol
      IS
         SELECT DISTINCT earning_policy
                    FROM hxt_add_assign_info_f
                   WHERE assignment_id = p_assignment_id
                     AND (   p_start_date BETWEEN effective_start_date
                                              AND effective_end_date
                          OR p_end_date BETWEEN effective_start_date
                                            AND effective_end_date
                         );
   BEGIN
      v_policy_exists := 'N';

      --Select person_id based on assignment id
      --      SELECT person_id
      --        INTO v_person_id
      --        FROM per_all_assignments_f
      --       WHERE assignment_id = p_assignment_id
      --         AND primary_flag = 'Y'
      --         AND p_end_date BETWEEN effective_start_date AND effective_end_date;
      FOR v_cur_rec IN cur_earn_pol
      LOOP
         v_policy_exists := 'Y';

         -- Fetching the Holiday Calendar attached to the Earning Policy
         BEGIN
            SELECT hcl_id
              INTO v_hcl_id
              FROM hxt_earning_policies hep
             WHERE hep.ID = v_cur_rec.earning_policy;
         EXCEPTION
            WHEN NO_DATA_FOUND
            THEN
               v_hcl_id := 0;
            WHEN TOO_MANY_ROWS
            THEN
               v_hcl_id := 0;
            WHEN OTHERS
            THEN
               v_hcl_id := 0;
         END;

         -- Taking the count of the holidays in the specified date range
         BEGIN
            SELECT COUNT (holiday_date)
              INTO v_no_of_nh
              FROM hxt_holiday_days hhd
             WHERE hcl_id = v_hcl_id
               AND holiday_date BETWEEN p_start_date AND p_end_date;
         EXCEPTION
            WHEN NO_DATA_FOUND
            THEN
               v_no_of_nh := 0;
            WHEN TOO_MANY_ROWS
            THEN
               v_no_of_nh := 0;
            WHEN OTHERS
            THEN
               v_no_of_nh := 0;
         END;
      END LOOP;

      --IF OTL Policy is not attached to the employee then pick the holidays from generic holiday calendar
      IF v_policy_exists = 'N'
      THEN
        --added for SR 354732
      Begin
      v_prl_name :=Null;
      select payroll_name into v_prl_name
      from apps.per_all_assignments_f paaf,pay_payrolls_f ppf
      where  1=1
        and assignment_id = p_assignment_id
        and assignment_type = 'E'
        and primary_flag ='Y'
        and paaf.payroll_id = ppf.payroll_id
        and  trunc(p_start_date) between trunc(paaf.effective_start_date ) and trunc(paaf.effective_end_date)
        and  trunc(p_start_date) between trunc(ppf.effective_start_date ) and trunc(ppf.effective_end_date);
        Exception When Others
        then v_prl_name :=null;
        End;
        --End for SR 354732

        -----added for SR 431846---

              v_region_name   := xxoa_payroll_all.get_region (81,
                                         p_assignment_id,
                                         p_start_date
                                        );
                                        ---end Sr 431846---

         -- Taking the count of the holidays in the specified date range
         BEGIN

          --added for SR 354732


         if ( (v_prl_name = 'KSA Payroll') OR (v_prl_name = 'Base Payroll' AND upper(v_region_name) = nvl('KSA','XX'))) ---added OR Condition for SR 431846
         then v_calendar_name := 'OA HQ Holiday Calendar – KSA';
		 ----added for SR 372255-------
		 ELSIF ((v_prl_name = 'Bahrain Payroll')  OR (v_prl_name = 'Base Payroll' AND upper(v_region_name) = nvl('BAHRAIN','XX')))---added OR Condition for SR 431846
		   then v_calendar_name := 'OA HQ Holiday Calendar – BAH';  ----END for SR 372255-------
		     ---added for SR 407907---
		   	   ELSIF ((v_prl_name = 'Qatar Payroll') OR (v_prl_name = 'Base Payroll' AND upper(v_region_name) = nvl('QATAR','XX')))---added OR Condition for SR 431846
		   then v_calendar_name := 'OA HQ Holiday Calendar – QTR';

		   ELSIF ((v_prl_name = 'Kuwait Payroll') OR (v_prl_name = 'Base Payroll' AND upper(v_region_name) = nvl('KUWAIT','XX')))---added OR Condition for SR 431846
		   then v_calendar_name := 'OA HQ Holiday Calendar – KWT';

		   	   ELSIF ((v_prl_name = 'UAE Payroll' ) OR (v_prl_name = 'Base Payroll' AND upper(v_region_name) = nvl('UAE','XX')))---added OR Condition for SR 431846
		   then v_calendar_name := 'OA HQ Holiday Calendar – UAE';  ---END for SR 407907---

         else v_calendar_name :='OA HQ Holiday Calendar';
         end if;
          --End for SR 354732t

            SELECT COUNT (holiday_date)
              INTO v_no_of_nh
              FROM hxt_holiday_days hhd, hxt_holiday_calendars hhc
             WHERE hhd.hcl_id = hhc.ID
               AND TRIM (UPPER (hhc.NAME)) = UPPER (v_calendar_name)---('OA HQ Holiday Calendar') ----Added for 354732
               AND holiday_date BETWEEN p_start_date AND p_end_date;
         EXCEPTION
            WHEN NO_DATA_FOUND
            THEN
               v_no_of_nh := 0;
            WHEN TOO_MANY_ROWS
            THEN
               v_no_of_nh := 0;
            WHEN OTHERS
            THEN
               v_no_of_nh := 0;
         END;
      END IF;

      RETURN v_no_of_nh;
   --Exception
   EXCEPTION
      WHEN NO_DATA_FOUND
      THEN
         RETURN -1;
      WHEN TOO_MANY_ROWS
      THEN
         RETURN -1;
      WHEN OTHERS
      THEN
         RETURN -1;
   END holidays;


