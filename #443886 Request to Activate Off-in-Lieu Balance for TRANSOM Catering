--Function to fetch leave count in a year
--------------------------------------------------------
   FUNCTION xxoa_lve_yr_cnt_uae (
      p_assignment_id   IN   NUMBER,
      p_date_start      IN   DATE,
      p_lve_type        IN   VARCHAR2
   )
      RETURN number
   IS
      cnt_leave   number ;

   BEGIN
     BEGIN
     cnt_leave :=0;

         	SELECT nvl(SUM(paa.absence_days),0)
					INTO cnt_leave
					FROM per_absence_attendances paa
						 ,per_absence_attendance_types paat
					WHERE paa.absence_attendance_type_id = paat.absence_attendance_type_id
						  AND upper(paat.name) = upper(p_lve_type)
						  AND person_id = (SELECT person_id
										   FROM per_all_assignments_f
											WHERE
													assignment_id = p_assignment_id
