--Function to fetch start date of first applied leave
--------------------------------------------------------
 FUNCTION xxoa_lve_st_date (
      p_assignment_id   IN   NUMBER,
      p_date_start      IN   DATE,
      p_lve_type        IN   VARCHAR2
   )
      RETURN DATE
   IS
      v_lve_st_date   DATE ;

   BEGIN
        	  BEGIN

                   v_lve_st_date :=NULL;

		         	SELECT ----min(paa.date_start)---nvl(SUM(paa.absence_days),0)
					nvl(min(paa.date_start),p_date_start)
					INTO v_lve_st_date
					FROM per_absence_attendances paa
						 ,per_absence_attendance_types paat
					WHERE paa.absence_attendance_type_id = paat.absence_attendance_type_id
						  AND upper(paat.name) = upper(p_lve_type)
						  AND person_id = (SELECT person_id
										   FROM per_all_assignments_f
											WHERE
													assignment_id = p_assignment_id
												AND primary_flag = 'Y'
												AND assignment_type = 'E'
												AND business_group_id = 81
												AND p_date_start BETWEEN effective_start_date AND effective_end_date
												AND rownum = 1)
						 AND  TRUNC(p_date_start,'RRRR') = TRUNC(paa.date_start,'RRRR');
			Exception When OTHERS
		THEN
			v_lve_st_date := p_date_start;
		END;

  RETURN nvl(v_lve_st_date,p_date_start);

END xxoa_lve_st_date;
