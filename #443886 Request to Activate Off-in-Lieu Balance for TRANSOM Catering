		 AND (   UPPER (v_absence_type) = UPPER ('Annual Leave')
              OR UPPER (v_absence_type) = UPPER ('Off in Lieu Bank')
             )
      THEN
         v_no_of_days := ((p_date_end - p_date_start) + 1);
      ELSE
	   IF
	     NVL (v_flying_staff, 'XX') <> 'FLY'
         AND (   UPPER (v_absence_type) = UPPER ('Annual Leave')
              OR UPPER (v_absence_type) = UPPER ('Leave Bank')
             )
      THEN
         v_no_of_days := ((p_date_end - p_date_start) + 1) - v_holidays;
      ELSE
         v_no_of_days := ((p_date_end - p_date_start) + 1);
      END IF;
      END IF;

