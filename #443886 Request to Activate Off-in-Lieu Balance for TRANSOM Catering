   FUNCTION working_days (
      p_assignment_id   IN   NUMBER,
      p_start_date      IN   DATE,
      p_end_date        IN   DATE
   )
      RETURN NUMBER
   IS
      --Local variable declaration
      v_working_days   NUMBER := 0;
      v_holidays       NUMBER := 0;
      v_days           NUMBER := 0;
   BEGIN
      v_days := (p_end_date - p_start_date) + 1;
      --get the number of holidays between start date and end date
      v_holidays := holidays (p_assignment_id, p_start_date, p_end_date);
      --get the number of working days
      v_working_days := v_days - v_holidays;
      RETURN v_working_days;
   EXCEPTION
      WHEN NO_DATA_FOUND
      THEN
         RETURN 0;
      WHEN TOO_MANY_ROWS
      THEN
         RETURN 0;
      WHEN OTHERS
      THEN
         RETURN 0;
   END working_days;
