   FUNCTION get_overlap_leave (
      p_assignment_id   NUMBER,
      p_start_date      DATE,
      p_end_date        DATE
   )
      RETURN NUMBER
   AS
      --Local variable declaration
      total_days    NUMBER          := 0;
      v_person_id   NUMBER;
      v_msg         VARCHAR2 (1000);

      --Cursor to get leaves applied for a specific person
      CURSOR c_applied_leave (cp_person_id NUMBER)
      IS
         SELECT TO_DATE ((   TO_CHAR (date_start, 'DD-MON-RRRR')
                          || ' '
                          || NVL (time_start, '00:00:00')
                         ),
                         'DD-MON-RRRR HH24:MI:SS'
                        ) date_start,
                TO_DATE ((   TO_CHAR (date_end, 'DD-MON-RRRR')
                          || ' '
                          || NVL (time_end, '23:59:59')
                         ),
                         'DD-MON-RRRR HH24:MI:SS'
                        ) date_end
           FROM per_absence_attendances
          WHERE person_id = cp_person_id
		  AND absence_days is not null  -- Added for SR 211752
		  ;

      --Cursor to get leaves pending for approval for a specific person
      CURSOR c_pend_leave (cp_person_id NUMBER)
      IS
         SELECT TO_DATE (information1, 'RRRR-MM-DD') start_date,
                TO_DATE (information2, 'RRRR-MM-DD') end_date
           FROM hr_api_transaction_steps
          WHERE 1 = 1
            AND transaction_id IN (
                   SELECT transaction_id
                     FROM hr_api_transactions hat
                    WHERE selected_person_id = cp_person_id
                      AND status IN ('Y')
                      AND transaction_ref_table = 'PER_ABSENCE_ATTENDANCES'
                      AND (   (    EXISTS (
                                      SELECT 1
                                        FROM wf_notifications wf
                                       WHERE wf.item_key = hat.item_key
                                         AND wf.message_name =
                                                    'HR_EMBED_RN_NTF_APPR_MSG')
                               AND EXISTS (
                                      SELECT 1
                                        FROM wf_notifications wf
                                       WHERE wf.item_key = hat.item_key
                                         AND wf.message_name =
                                                    'HR_EMBED_RN_NTF_APPR_MSG'
                                         AND end_date IS NULL)
                              )
                           OR NOT EXISTS (
                                 SELECT 1
                                   FROM wf_notifications wf
                                  WHERE wf.item_key = hat.item_key
                                    AND wf.message_name =
                                                    'HR_EMBED_RN_NTF_APPR_MSG')
                          ));
   BEGIN
      BEGIN
         --get the person id based on assignment id
         SELECT person_id
           INTO v_person_id
           FROM per_all_assignments_f
          WHERE assignment_id = p_assignment_id
            AND p_start_date BETWEEN effective_start_date AND effective_end_date
            AND primary_flag = 'Y';
      EXCEPTION
         WHEN NO_DATA_FOUND
         THEN
            RETURN 0;
         WHEN TOO_MANY_ROWS
         THEN
            RETURN 0;
         WHEN OTHERS
         THEN
            RETURN 0;
      END;

      FOR rec_applied_leave IN c_applied_leave (v_person_id)
      LOOP
         DBMS_OUTPUT.put_line ('Inside the First Loop');
         DBMS_OUTPUT.put_line ('p_start_date' || '-' || p_start_date);
         DBMS_OUTPUT.put_line ('p_end_date' || '-' || p_end_date);
         DBMS_OUTPUT.put_line (   'start_date'
                               || '-'
                               || rec_applied_leave.date_start
                              );
         DBMS_OUTPUT.put_line ('end_date' || '-' || rec_applied_leave.date_end);

         --Check If the start date of the leave is between already applied leaves
         IF p_start_date BETWEEN rec_applied_leave.date_start
                             AND rec_applied_leave.date_end
         THEN
            DBMS_OUTPUT.put_line ('Inside the First if condition');
            RETURN 2;
         END IF;

         --Check If the end date of the leave is between already applied leaves
         IF p_end_date BETWEEN rec_applied_leave.date_start
                           AND rec_applied_leave.date_end
         THEN
            DBMS_OUTPUT.put_line ('Inside the Second if condition');
            RETURN 2;
         END IF;

		   -- Added for SR 186514 :: START
		IF (rec_applied_leave.date_start BETWEEN p_start_date AND p_end_date)
		  OR (rec_applied_leave.date_end BETWEEN p_start_date AND p_end_date)          THEN
            RETURN 2;
         END IF;
		       -- Added for SR 186514 :: END
      END LOOP;

      FOR rec_pend_leave IN c_pend_leave (v_person_id)
      LOOP
         --Check If the start date of the leave is between already applied leaves awaiting approval
         IF p_start_date BETWEEN rec_pend_leave.start_date
                             AND rec_pend_leave.end_date
         THEN
            RETURN 1;
         END IF;

         --Check If the end date of the leave is between already applied leaves awaiting approval
         IF p_end_date BETWEEN rec_pend_leave.start_date
                           AND rec_pend_leave.end_date
         THEN
            RETURN 1;
         END IF;

         -- Added By Sameer Patil Start here
         IF (   rec_pend_leave.start_date BETWEEN p_start_date AND p_end_date
             OR rec_pend_leave.end_date BETWEEN p_start_date AND p_end_date
            )
         THEN
            RETURN 1;
         END IF;
      -- Added By Sameer Patil Ends here
      END LOOP;

      RETURN 0;
   --Exception
   EXCEPTION
      WHEN NO_DATA_FOUND
      THEN
         RETURN 0;
      WHEN TOO_MANY_ROWS
      THEN
         RETURN 0;
      WHEN OTHERS
      THEN
         RETURN 0;
   END get_overlap_leave;

