-- ----------------------------------------------------------------------------
-- |-------------------------< Calculate overtime eligibility >--------------------------|
-- ----------------------------------------------------------------------------
   FUNCTION calculate_overtime_eligibility (
      p_assg_id              NUMBER,
      date_worked            VARCHAR2,
      p_absence_start_date   DATE,
      p_absence_end_date     DATE
   )
      RETURN VARCHAR2
   IS
      --Local variable declaration
      v_difference     NUMBER          := 0;
      v_invalid_msg    VARCHAR2 (2000) := 'NOERROR';
      v_dateworked     DATE;
      v_str_date       VARCHAR2 (100);
      v_new_str_date   VARCHAR2 (100);
      v_person_id      NUMBER;
      v_leave_days     NUMBER;
      v_segment1       VARCHAR2 (50);
   BEGIN
      v_invalid_msg := 'NOERROR';

      IF v_leave_days > 1
      THEN
         v_invalid_msg := 'XXOA_HR_COMPOFF_DURATION';
      END IF;

      v_str_date := date_worked;
      v_dateworked := TO_DATE (date_worked, 'RRRR/MM/DD HH24:MI:SS');
      v_difference := (p_absence_start_date) - (v_dateworked);

      IF v_difference > 60
      THEN
         v_invalid_msg := 'XXOA_HR_COMPOFF_DIFFERENCE';
         RETURN v_invalid_msg;
      ELSE
         BEGIN
            --get the person id from assignment id
            SELECT papf.person_id
              INTO v_person_id
              FROM per_all_people_f papf, per_all_assignments_f paaf
             WHERE papf.person_id = paaf.person_id
               AND paaf.assignment_id = p_assg_id
               AND TRUNC (v_dateworked) BETWEEN papf.effective_start_date
                                            AND papf.effective_end_date
               AND TRUNC (v_dateworked) BETWEEN paaf.effective_start_date
                                            AND paaf.effective_end_date;
         EXCEPTION
            WHEN NO_DATA_FOUND
            THEN
               v_invalid_msg := 'XXOA_HR_COMPOFF_EMPLOYEE_EXCEP';
            WHEN TOO_MANY_ROWS
            THEN
               v_invalid_msg := 'XXOA_HR_COMPOFF_EMPLOYEE_EXCEP';
            WHEN OTHERS
            THEN
               v_invalid_msg := 'XXOA_HR_COMPOFF_EMPLOYEE_EXCEP';
               RETURN v_invalid_msg;
         END;

         BEGIN
            SELECT pac.segment1
              INTO v_segment1
              FROM per_analysis_criteria pac,
                   per_person_analyses ppa,
                   fnd_id_flex_structures fifs
             WHERE pac.analysis_criteria_id = ppa.analysis_criteria_id
               AND pac.id_flex_num = fifs.id_flex_num
               AND TRIM (ppa.person_id) = v_person_id
               AND TO_DATE (pac.segment1, 'RRRR/MM/DD HH24:MI:SS') =
                                                                  v_dateworked
               AND TRUNC (v_dateworked) BETWEEN ppa.date_from
                                            AND NVL (ppa.date_to,
                                                     hr_general.end_of_time
                                                    )
               AND pac.enabled_flag = 'Y'
               AND fifs.id_flex_structure_code = 'OA_COMP_OFF_INFO';
         EXCEPTION
            WHEN NO_DATA_FOUND
            THEN
               v_invalid_msg := 'XXOA_HR_COMPOFF_SIT_NO_DATA';
            WHEN TOO_MANY_ROWS
            THEN
               v_invalid_msg := 'XXOA_HR_COMPOFF_SIT_TOO_MANY';
            WHEN OTHERS
            THEN
               v_invalid_msg := 'XXOA_HR_COMPOFF_SIT_EXCEP';
               RETURN v_invalid_msg;
         END;

         v_segment1 := TO_DATE (v_segment1, 'RRRR/MM/DD HH24:MI:SS');

         IF v_segment1 <> v_dateworked
         THEN
            v_invalid_msg := 'XXOA_HR_COMPOFF_DATE';
            RETURN v_invalid_msg;
         END IF;
      END IF;

      RETURN v_invalid_msg;
   EXCEPTION
      WHEN NO_DATA_FOUND
      THEN
         RETURN 'XX';
      WHEN TOO_MANY_ROWS
      THEN
         RETURN 'XX';
      WHEN OTHERS
      THEN
         RETURN 'XX';
   END calculate_overtime_eligibility;

