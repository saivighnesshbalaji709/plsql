   FUNCTION get_leave_ent (
      p_assignment_id            NUMBER,
      p_accrual_plan_name   IN   VARCHAR2,
      p_date                     DATE
   )
      RETURN NUMBER
   AS
      --Local variable declaration
      v_leave_ent   NUMBER          := 0;
      v_err_msg     VARCHAR2 (1000);
   BEGIN
      --get the annual leave balance as on the specifed date for an employee
      SELECT pay_us_pto_accrual.get_net_accrual (pva1.assignment_id,
                                                 p_date,
                                                 pva1.accrual_plan_id,
                                                 pva1.accrual_category,
                                                 ''
                                                ) leave_entl
        INTO v_leave_ent
        FROM per_all_assignments_f paaf, pay_view_accrual_plans_v pva1
       WHERE 1 = 1
         AND pva1.assignment_id = paaf.assignment_id
         AND paaf.primary_flag = 'Y'
         AND p_date BETWEEN paaf.effective_start_date AND paaf.effective_end_date
         AND p_date BETWEEN pva1.asg_effective_start_date
                        AND pva1.asg_effective_end_date
         AND p_date BETWEEN pva1.e_entry_effective_start_date
                        AND pva1.e_entry_effective_end_date
		 AND p_date BETWEEN pva1.e_link_effective_start_date
                        AND pva1.e_link_effective_end_date -- Added for SR 256881
         AND UPPER (TRIM (pva1.accrual_plan_name)) =
                                            UPPER (TRIM (p_accrual_plan_name))
         AND paaf.assignment_id = p_assignment_id;

      RETURN v_leave_ent;
   EXCEPTION
      WHEN NO_DATA_FOUND
      THEN
         RETURN -9999999;
      WHEN TOO_MANY_ROWS
      THEN
         RETURN -9999999;
      WHEN OTHERS
      THEN
         RETURN -9999999;
   END;

