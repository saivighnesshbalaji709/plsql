         --Check If the end date of the leave is between already applied leaves awaiting approval
         IF p_end_date BETWEEN rec_pend_leave.start_date
                           AND rec_pend_leave.end_date
         THEN
            RETURN 1;
         END IF;
      END LOOP;

      RETURN 0;
   EXCEPTION
