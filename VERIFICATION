            WHEN OTHERS
            THEN
               fnd_file.put_line (fnd_file.LOG,'Failure - ' || rec_ol_lev.person_analysis_id || ' - ' || SQLERRM);
            END;
		END IF;
	  End if;

	 END Loop;


		BEGIN
        fnd_global.apps_initialize (l_user_id, l_resp_id , l_resp_appl_id);
