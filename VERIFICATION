   ----------------------------------------------------------------------
   PROCEDURE OA_OffinLieu_Leave_Adj_proc (
      p_errbuf    OUT   VARCHAR2,
      p_retcode   OUT   NUMBER

   ) is

   v_date                DATE;
   v_element_type_id  NUMBER;
   v_valid_record   VARCHAR2 (10);
   v_err_msg  VARCHAR2 (1000) := NULL;
   v_request_id                       NUMBER;
   l_batch_id                         NUMBER := NULL;
   l_object_version_number             NUMBER := NULL;
   v_batch_name                     VARCHAR2(1000);
   v_batch_line_id                    NUMBER := NULL;
   v_batch_object_version_number     NUMBER;
   v_request_id1                     NUMBER;
   l_user_id     NUMBER;
   l_resp_id     NUMBER;
   l_resp_appl_id NUMBER;
   l_process VARCHAR2(10) :='N';
   l_analysis_criteria_id number := NULL;


   CURSOR C_jnr_lev_adj
          is
		  SELECT  pac.ROWID,papf.employee_number employee_number,ppa.person_analysis_id,ppa.object_version_number,pac.analysis_criteria_id,
                papf.full_name employee_name,
                pac.creation_date,fifs.id_flex_structure_code,papf.person_id ,
                paaf.assignment_id ,paaf.assignment_number
          FROM per_all_people_f papf,
                per_person_analyses ppa,
                per_analysis_criteria pac,
                fnd_id_flex_structures fifs,
                per_all_assignments_f paaf
          WHERE papf.person_id = ppa.person_id
            AND   paaf.primary_flag             = 'Y'
            AND paaf.person_id             = papf.person_id
            AND ppa.analysis_criteria_id = pac.analysis_criteria_id
            AND pac.id_flex_num = fifs.id_flex_num
            AND TRUNC (ppa.creation_date) BETWEEN papf.effective_start_date
                                              AND papf.effective_end_date
           AND sysdate BETWEEN paaf.effective_start_date
                            AND paaf.effective_end_date
            AND fifs.id_flex_structure_code = 'OA_OFF_IN_LIEU_REQUEST'
            AND pac.segment3  is NULL;

	BEGIN


           v_request_id     := fnd_profile.value('conc_request_id');
	  	   l_user_id       := fnd_global.user_id;
           l_resp_id       := fnd_global.resp_id;
           l_resp_appl_id  := fnd_global.resp_appl_id;

	  	   v_batch_name:='LCO'||v_request_id||'-'||TO_CHAR(SYSDATE,'DDMONRRRR');

          fnd_file.put_line (fnd_file.log, 'v_batch_name '||v_batch_name);  ---  Batch creation
           BEGIN
           pay_batch_element_entry_api.create_batch_header (
               p_session_date            => TRUNC (SYSDATE),
               p_batch_name              => v_batch_name,
               p_business_group_id       => 81,
               p_action_if_exists        => 'I',
               p_batch_id                => l_batch_id,
               p_reject_if_results_exists=> 'N',
               p_object_version_number   => l_object_version_number);
           COMMIT;
           fnd_file.put_line (fnd_file.output, 'Batch Created ....'||v_batch_name);
          EXCEPTION
           WHEN OTHERS
           THEN
               v_valid_record := 'N';
               v_err_msg :=
                     'Error in creating batch '
                  || SUBSTR (SQLERRM, 1, 100);
               fnd_file.put_line (fnd_file.LOG,
                                     'Error in creating batch '|| v_err_msg );
        END;

	  ---- element_type_id is deriving for Annual Leave Adjustment
	  BEGIN
            SELECT element_type_id
              INTO v_element_type_id
              FROM pay_element_types_f
             WHERE UPPER (element_name) = UPPER ('Annual Leave Adjustment')
               AND trunc(sysdate) BETWEEN effective_start_date AND effective_end_date
               AND business_group_id = 81;

         EXCEPTION
            WHEN NO_DATA_FOUND
            THEN
               v_valid_record := 'N';
               v_err_msg := 'No element is defined';
               fnd_file.put_line (fnd_file.LOG,
                                     v_err_msg
                                 );
            WHEN TOO_MANY_ROWS
            THEN
               v_valid_record := 'N';
               v_err_msg := 'Multiple element is fetched';
               fnd_file.put_line (fnd_file.LOG,
                                     v_err_msg
                                 );
            WHEN OTHERS
            THEN
               v_valid_record := 'N';
               v_err_msg := 'Error in getting element: ' || SUBSTR (SQLERRM, 1, 100);
               fnd_file.put_line (fnd_file.LOG,
                                    v_err_msg
                                 );
         END;


	FOR rec_jnr_lev IN C_jnr_lev_adj
	LOOP

    BEGIN
	        l_process:='N';
            fnd_date.initialize ('DD-MON-RRRR', NULL);
                pay_batch_element_entry_api.create_batch_line (
                    p_session_date           => TRUNC (SYSDATE),
                    p_batch_id               => l_batch_id,
                    p_assignment_id          => rec_jnr_lev.assignment_id,
                    p_assignment_number     => rec_jnr_lev.assignment_number,
                    p_effective_date        => rec_jnr_lev.creation_date,
                    p_element_name          => 'Annual Leave Adjustment',
                    p_element_type_id         => v_element_type_id,
                    p_attribute10           =>'Y',
                    p_value_1                 => 1,
                    p_value_2                 => rec_jnr_lev.creation_date,
                    p_batch_line_id            => v_batch_line_id,
                    p_object_version_number => v_batch_object_version_number);

               fnd_file.put_line (fnd_file.output,
                                     'Leave Bank for Employee Number :  '
                                  || rec_jnr_lev.employee_number
                                  || '     Created Successfully with :'
                                  || 1
                                  || '     Days'
                                 );

					l_process := 'S';
              EXCEPTION
               WHEN OTHERS
               THEN
                  v_valid_record := 'N';
				  l_process := 'E';
                  v_err_msg :=
                        'Error during element entry: '
                     || SUBSTR (SQLERRM, 1, 100);
                  fnd_file.put_line (fnd_file.LOG,
                                        'Employee Number: '
                                     || rec_jnr_lev.employee_number
                                     || v_err_msg
                                    );
				  fnd_file.put_line (fnd_file.LOG,
                                        'l_process: '
                                     || l_process
                                       );
      END;

      if l_process='S' then

	        BEGIN
			       l_analysis_criteria_id := NULL;

	         hr_sit_api.update_sit (  p_validate                    => FALSE,
                                      p_person_analysis_id          => rec_jnr_lev.person_analysis_id,
                                      p_pea_object_version_number   => rec_jnr_lev.object_version_number,
                                      p_segment3                    => 'P',
                                      p_analysis_criteria_id        => l_analysis_criteria_id);

            COMMIT;
            fnd_file.put_line (fnd_file.LOG,rec_jnr_lev.person_analysis_id|| ' has been updated Successfully !!!!');
			fnd_file.put_line (fnd_file.LOG,'l_analysis_criteria_id :'|| l_analysis_criteria_id);

            EXCEPTION
            WHEN OTHERS
            THEN
               fnd_file.put_line (fnd_file.LOG,'Failure - ' || rec_jnr_lev.person_analysis_id || ' - ' || SQLERRM);
            END;

	  End if;

	 END Loop;


		BEGIN
        fnd_global.apps_initialize (l_user_id, l_resp_id , l_resp_appl_id);
        v_request_id1 :=
            fnd_request.submit_request (
                application   => 'PER',
                program       => 'PAYLINK(TRANSFER)',
                description   => 'Transfers BEE batch',
                start_time    => SYSDATE,
                sub_request   => FALSE,
                argument1     => 'BATCHEE',
                argument2     => 'TRANSFER',
                argument3     => l_batch_id);
        COMMIT;
     fnd_file.put_line (fnd_file.output,
                                     v_batch_name||' BEE transferred successfully '
                                 );
    END;

	 EXCEPTION
      WHEN OTHERS
      THEN
         fnd_file.put_line (fnd_file.LOG,
                            'Error In Main Program' || SQLERRM || SQLCODE
                           );
   END OA_OffinLieu_Leave_Adj_proc;
   -- Changes Ends for SR 339680 ---


