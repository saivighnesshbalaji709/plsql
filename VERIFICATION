                      segment29 = v_error
                WHERE ROWID = lev_can.ROWID;

          		   COMMIT;
               fnd_file.put_line (fnd_file.output, '<G_EMP_INC>');
               fnd_file.put_line (fnd_file.output,
                                     '<EMPLOYEE_NUMBER>'
                                  || lev_can.employee_number
                                  || '</EMPLOYEE_NUMBER>'
                                 );
               fnd_file.put_line (fnd_file.output,
                                     '<EMPLOYEE_NAME>'
                                  || lev_can.employee_name
                                  || '</EMPLOYEE_NAME>'
                                 );
               fnd_file.put_line (fnd_file.output,
                                     '<LEAVE_TYPE>'
                                  || lev_can.leave_type
                                  || '</LEAVE_TYPE>'
                                 );
               fnd_file.put_line (fnd_file.output,
                                     '<START_DATE>'
                                  || lev_can.leave_start_date
                                  || '</START_DATE>'
                                 );
               fnd_file.put_line (fnd_file.output,
                                     '<END_DATE>'
