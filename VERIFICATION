                    AND hr.lookup_type = 'XXOA_LEAVE_CANCELLATION'
                    AND hr.enabled_flag = 'Y'
                    AND hr.lookup_code = pac.segment1) leave_type,
                pac.segment2 leave_start_date, pac.segment3 leave_end_date,
                pac.segment4 cancellation_reason,
                (SELECT paa.absence_attendance_id
                   FROM per_absence_attendances paa,
                        per_absence_attendance_types paat,
                        hr_lookups hr
                  WHERE 1 = 1
                    AND paa.absence_attendance_type_id =
                                               paat.absence_attendance_type_id
                    AND person_id = papf.person_id
                    AND paa.date_start =
                                     fnd_date.canonical_to_date (pac.segment2)
                    AND paa.date_end =
                                     fnd_date.canonical_to_date (pac.segment3)
                    AND UPPER (TRIM (hr.meaning)) = UPPER (TRIM (paat.NAME))
                    AND UPPER (TRIM (hr.lookup_code)) =
                                                   UPPER (TRIM (pac.segment1))
                    AND hr.lookup_type = 'XXOA_LEAVE_CANCELLATION'
                    AND hr.enabled_flag = 'Y') abs_att_id,
                (SELECT paa.object_version_number
                   FROM per_absence_attendances paa,
                        per_absence_attendance_types paat,
                        hr_lookups hr
                  WHERE 1 = 1
                    AND paa.absence_attendance_type_id =
                                               paat.absence_attendance_type_id
                    AND person_id = papf.person_id
                    AND paa.date_start =
                                     fnd_date.canonical_to_date (pac.segment2)
                    AND paa.date_end =
                                     fnd_date.canonical_to_date (pac.segment3)
                    AND UPPER (TRIM (hr.meaning)) = UPPER (TRIM (paat.NAME))
                    AND UPPER (TRIM (hr.lookup_code)) =
                                                   UPPER (TRIM (pac.segment1))
                    AND hr.lookup_type = 'XXOA_LEAVE_CANCELLATION'
                    AND hr.enabled_flag = 'Y') ovn
           FROM per_all_people_f papf,
                per_person_analyses ppa,
                per_analysis_criteria pac,
                fnd_id_flex_structures fifs
          WHERE papf.person_id = ppa.person_id
            AND ppa.analysis_criteria_id = pac.analysis_criteria_id
            AND pac.id_flex_num = fifs.id_flex_num
            AND TRUNC (ppa.creation_date) BETWEEN papf.effective_start_date
                                              AND papf.effective_end_date
            AND fifs.id_flex_structure_code = 'XXOA_LEAVE_CANCELLATION'
            AND NVL (segment30, 'E') = 'E'
            AND TRUNC (ppa.creation_date) >= '08-JUN-2016'
			 ;*/
       -- Added for SR 223519 :: START
      SELECT  pac.ROWID,papf.employee_number employee_number,
                papf.full_name employee_name,
                (SELECT hr.meaning
                   FROM hr_lookups hr
                  WHERE 1 = 1
                    AND hr.lookup_type = 'XXOA_LEAVE_CANCELLATION'
                    AND hr.enabled_flag = 'Y'
                    AND hr.lookup_code = pac.segment1) leave_type,
                pac.segment2 leave_start_date, pac.segment3 leave_end_date,
                pac.segment4 cancellation_reason,
                paa.absence_attendance_id abs_att_id,
                paa.object_version_number ovn
          FROM per_all_people_f papf,
