        IF ( c_emp_grp_cnt = 0 OR c_emp_type_cnt = 0 OR c_emp_grd_cnt =  0 )
        THEN
        p_duration := 'FAILED';
        p_invalid_msg := 'You are not allowed to apply this type of leave.';
        RETURN 1;
        END IF;

		IF trunc(p_date_start) < to_date('01-Oct-2025')
        THEN
        p_duration := 'FAILED';
        p_invalid_msg := 'You can not apply for this leave before 01-Oct-2025 .';
        RETURN 1;
        END IF;

