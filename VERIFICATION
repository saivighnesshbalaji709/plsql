SELECT  pac.ROWID,papf.employee_number employee_number,
TO_DATE(pac.segment2, 'YYYY-MM-DD HH24:MI:SS') seg_date,
ppa.person_analysis_id,ppa.object_version_number,pac.analysis_criteria_id,
