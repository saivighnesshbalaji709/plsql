  IF UPPER (v_absence_type) = UPPER ('Off In Lieu Bank')
         THEN


		 BEGIN
		 v_grade:=null;
		 v_emp_grp := null;
		 v_emp_type := null;
            select flv.meaning EMPLOYEE_GROUP,
         flv1.meaning EMPLOYEE_TYPE,prg.name  Grade into v_emp_grp , v_emp_type ,v_grade
		from  per_all_people_f papf  ,fnd_lookup_values flv ,
          fnd_lookup_values flv1,per_all_assignments_f paaf, pay_people_groups ppg,per_grades prg
		where 1=1
		---and papf.employee_number ='1240'
		and paaf.assignment_id = p_assignment_id
		and paaf.assignment_type='E'
		and paaf.primary_flag='Y'
		and prg.grade_id = paaf.grade_id
		and papf.current_employee_flag ='Y'
		and paaf.person_id=papf.person_id
		and  trunc(sysdate) between prg.date_from and nvl(prg.date_to, to_date('31-Dec-4712'))
		and  trunc(sysdate) between paaf.effective_start_date and paaf.effective_end_date
		and  trunc(sysdate) between papf.effective_start_date and papf.effective_end_date
		AND ppg.people_group_id(+) = paaf.people_group_id
			 AND flv.lookup_type(+) = 'XXOA_HQ_EMPLOYEE_GROUP'
			 AND flv.language(+)    = 'US'
			 AND ppg.segment1       = flv.lookup_code(+)
			 AND  ppg.segment2 =flv1.lookup_code(+)
			 AND flv1.lookup_type(+) = 'XXOA_HQ_EMPLOYEE_TYPE'
			 AND flv1.language(+)    = 'US'  ;
         EXCEPTION
            WHEN OTHERS
            THEN
         v_grade:=null;
		 v_emp_grp := null;
		 v_emp_type := null;
         END;


        Begin
        c_emp_grp_cnt :=0;

         SELECT count(1) into c_emp_grp_cnt
		 FROM apps.fnd_lookup_values_vl flv
                            WHERE
                            flv.lookup_type = 'XXOA_OFFIN_LIEU_EMP_GROUP'
                            AND flv.enabled_flag = 'Y'
							AND flv.meaning = v_emp_grp
                            AND sysdate BETWEEN flv.start_date_active AND nvl(flv.end_date_active, to_date('31-DEC-4712'));
        Exception when others then
        c_emp_grp_cnt := 0;
        End ;
		
		----Added for SR#443886: STARTS-----------
		 Begin
    c_emp_type_cnt :=0;
 
		IF v_payroll_id = 341   ---- CONFIRM actual payroll_id for Catering Payroll
		THEN
			LOG('Catering payroll');
	 
			SELECT count(1) into c_emp_type_cnt
			FROM apps.fnd_lookup_values_vl flv
								WHERE
								flv.lookup_type = 'XXOA_OFFIN_LIEU_EMP_TYPE_CAT'
								AND flv.enabled_flag = 'Y'
								AND flv.meaning = v_emp_type
								AND sysdate BETWEEN flv.start_date_active AND nvl(flv.end_date_active, to_date('31-DEC-4712'));
		ELSE
			SELECT count(1) into c_emp_type_cnt
			FROM apps.fnd_lookup_values_vl flv
								WHERE
								flv.lookup_type = 'XXOA_OFFIN_LIEU_EMP_TYPE'
								AND flv.enabled_flag = 'Y'
								AND flv.meaning = v_emp_type
								AND sysdate BETWEEN flv.start_date_active AND nvl(flv.end_date_active, to_date('31-DEC-4712'));
		END IF;
	 
		Exception when others then
		c_emp_type_cnt := 0;
		End ;

    c_emp_grd_cnt :=0;
 
		IF v_payroll_id = 341  
		THEN
			LOG('Catering Payroll');
	 
			SELECT count(1) into c_emp_grd_cnt
			FROM apps.fnd_lookup_values_vl flv
								WHERE
								flv.lookup_type = 'XXOA_OFFIN_LIEU_EMP_GRADES_CAT'
								AND flv.enabled_flag = 'Y'
								AND flv.meaning = v_grade
								AND sysdate BETWEEN flv.start_date_active AND nvl(flv.end_date_active, to_date('31-DEC-4712'));
		ELSE
			SELECT count(1) into c_emp_grd_cnt
			FROM apps.fnd_lookup_values_vl flv
								WHERE
								flv.lookup_type = 'XXOA_OFFIN_LIEU_EMP_GRADES'
								AND flv.enabled_flag = 'Y'
								AND flv.meaning = v_grade
								AND sysdate BETWEEN flv.start_date_active AND nvl(flv.end_date_active, to_date('31-DEC-4712'));
		END IF;
	 
		Exception when others then
		c_emp_grd_cnt := 0;
		End ;
 
        ----Added for SR#443886: ENDS-----------

